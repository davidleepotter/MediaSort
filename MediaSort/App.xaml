<Application x:Class="MediaSort.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <SolidColorBrush x:Key="PanelBackground" Color="#1E1E1E"/>
            <SolidColorBrush x:Key="PanelForeground" Color="#EEEEEE"/>
            <SolidColorBrush x:Key="AccentBrush" Color="#2D7BD4"/>
            <SolidColorBrush x:Key="BorderBrush" Color="#333333"/>

            <Style TargetType="Button" x:Key="ToolButton">
                <Setter Property="Background" Value="#2A2A2A"/>
                <Setter Property="Foreground" Value="#EEEEEE"/>
                <Setter Property="BorderBrush" Value="#444"/>
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="MinWidth" Value="80"/>
            </Style>

            <Style TargetType="Button" x:Key="DestButton">
                <Setter Property="Background" Value="#2D7BD4"/>
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="BorderBrush" Value="#1E5A9E"/>
                <Setter Property="Padding" Value="8,6"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="MinHeight" Value="42"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
