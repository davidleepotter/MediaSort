<Application x:Class="MediaSort.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             StartupUri="Views/MainWindow.xaml">
    <Application.Resources>
        <ResourceDictionary>
            <!-- Placeholder brushes; ThemeManager replaces these at startup -->
            <SolidColorBrush x:Key="WindowBackground"   Color="#181818"/>
            <SolidColorBrush x:Key="PanelBackground"    Color="#1E1E1E"/>
            <SolidColorBrush x:Key="PanelHeader"        Color="#252525"/>
            <SolidColorBrush x:Key="PanelForeground"    Color="#EEEEEE"/>
            <SolidColorBrush x:Key="MutedForeground"    Color="#AAAAAA"/>
            <SolidColorBrush x:Key="BorderBrushColor"   Color="#333333"/>
            <SolidColorBrush x:Key="AccentBrush"        Color="#2D7BD4"/>
            <SolidColorBrush x:Key="AccentForeground"   Color="White"/>
            <SolidColorBrush x:Key="ButtonBackground"   Color="#2A2A2A"/>
            <SolidColorBrush x:Key="ButtonForeground"   Color="#EEEEEE"/>
            <SolidColorBrush x:Key="ButtonBorder"       Color="#444444"/>
            <SolidColorBrush x:Key="InputBackground"    Color="#2A2A2A"/>
            <SolidColorBrush x:Key="ItemBackground"     Color="#262626"/>
            <SolidColorBrush x:Key="PreviewBackground"  Color="#0F0F0F"/>
            <SolidColorBrush x:Key="SplitterBrush"      Color="#0A0A0A"/>
            <SolidColorBrush x:Key="EmptyForeground"    Color="#666666"/>

            <!-- Pane-header accent stripes — 3px colored bar across the top
                 of each pane header. Reinforces the function-grouping color
                 vocabulary (purple=source, teal=preview, blue=destinations). -->
            <SolidColorBrush x:Key="SourceAccentStripe"      Color="#7B5599"/>
            <SolidColorBrush x:Key="PreviewAccentStripe"     Color="#5599A3"/>
            <SolidColorBrush x:Key="DestinationAccentStripe" Color="#5588C8"/>

            <!-- ============================================================
                 Implicit (un-keyed) styles must be declared BEFORE keyed
                 styles that reference them via BasedOn={StaticResource ...}.
                 ============================================================ -->

            <!-- Default Button: full template override so Aero doesn't bleed white -->
            <Style TargetType="Button">
                <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="MinHeight" Value="24"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBackground}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- TextBox -->
            <Style TargetType="TextBox">
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="4,2"/>
                <Setter Property="CaretBrush" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="SelectionBrush" Value="{DynamicResource AccentBrush}"/>
            </Style>

            <!-- CheckBox: default Aero template renders the glyph in white on white
                 in dark mode (the system always uses the user's OS theme for the
                 glyph, ignoring our Foreground brush). Provide a full template that
                 uses our theme brushes so checkmarks are visible in both themes. -->
            <Style TargetType="CheckBox">
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="Background" Value="{DynamicResource InputBackground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel Orientation="Horizontal" Background="Transparent">
                                <Grid Width="15" Height="15" VerticalAlignment="Center">
                                    <Border x:Name="Box"
                                            Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}"
                                            CornerRadius="2"
                                            SnapsToDevicePixels="True"/>
                                    <!-- Theme-foreground check glyph (PanelForeground) so it
                                         contrasts on InputBackground in either theme. -->
                                    <Path x:Name="Check"
                                          Stroke="{DynamicResource PanelForeground}"
                                          StrokeThickness="2"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Data="M 2 7 L 6 11 L 12 4"
                                          Visibility="Collapsed"
                                          SnapsToDevicePixels="True"/>
                                    <Rectangle x:Name="Indeterminate"
                                               Fill="{DynamicResource PanelForeground}"
                                               Width="8" Height="2"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               Visibility="Collapsed"/>
                                </Grid>
                                <ContentPresenter Margin="6,0,0,0"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  RecognizesAccessKey="True"/>
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="Box" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="Check" Property="Stroke" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="{x:Null}">
                                    <Setter TargetName="Indeterminate" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ThumbTileCheckBox: high-contrast checkbox for the thumbnail tiles.
                 The default Aero CheckBox glyph is dark blue/gray on white, which
                 disappears on top of the dark image overlay. This template draws
                 a black background box with a thick white check so it stays
                 visible at a glance on any thumbnail. -->
            <Style x:Key="ThumbTileCheckBox" TargetType="CheckBox">
                <Setter Property="Foreground" Value="White"/>
                <Setter Property="Background" Value="#CC000000"/>
                <Setter Property="BorderBrush" Value="White"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <Grid>
                                <Border x:Name="Box"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="2"
                                        SnapsToDevicePixels="True"/>
                                <!-- White check glyph: visible on the dark background. -->
                                <Path x:Name="Check"
                                      Stroke="White"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M 3 9 L 7 13 L 14 5"
                                      Visibility="Collapsed"
                                      SnapsToDevicePixels="True"/>
                                <!-- Indeterminate state: white horizontal bar. -->
                                <Rectangle x:Name="Indeterminate"
                                           Fill="White" Width="10" Height="2"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                           Visibility="Collapsed"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="Box" Property="Background" Value="#E62D7BD4"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="{x:Null}">
                                    <Setter TargetName="Indeterminate" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Box" Property="BorderBrush" Value="#CCFFFFFF"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ListBoxItem: container transparent so DataTemplate background shows -->
            <Style TargetType="ListBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="Padding" Value="2"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent" BorderThickness="1"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBackground}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ListViewItem: needs its OWN template that uses GridViewRowPresenter,
                 otherwise only the first GridViewColumn renders (because a plain
                 ContentPresenter only shows the bound item, not per-column values). -->
            <Style TargetType="ListViewItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListViewItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="Transparent" BorderThickness="0"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <GridViewRowPresenter
                                    Columns="{TemplateBinding GridView.ColumnCollection}"
                                    Content="{TemplateBinding Content}"
                                    SnapsToDevicePixels="{TemplateBinding SnapsToDevicePixels}"
                                    VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBackground}"/>
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- GridView column header -->
            <Style TargetType="GridViewColumnHeader">
                <Setter Property="Background" Value="{DynamicResource PanelHeader}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="BorderThickness" Value="0,0,1,1"/>
                <Setter Property="Padding" Value="6,4"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="GridViewColumnHeader">
                            <Grid>
                                <Border x:Name="HeaderBorder"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}">
                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"/>
                                </Border>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HeaderBorder" Property="Background" Value="{DynamicResource ItemBackground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Column-resize gripper between headers -->
            <Style TargetType="Thumb" x:Key="{ComponentResourceKey TypeInTargetAssembly={x:Type GridViewColumnHeader}, ResourceId=GridViewColumnHeaderGripper}">
                <Setter Property="Width" Value="8"/>
                <Setter Property="Background" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border Background="Transparent" Padding="3,0">
                                <Rectangle Width="1" Fill="{DynamicResource BorderBrushColor}"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Toggle button used inside the ComboBox template -->
            <ControlTemplate x:Key="ComboBoxToggleButtonTemplate" TargetType="ToggleButton">
                <Border x:Name="Bd"
                        Background="{DynamicResource ButtonBackground}"
                        BorderBrush="{DynamicResource ButtonBorder}"
                        BorderThickness="1"
                        SnapsToDevicePixels="True">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                        </Grid.ColumnDefinitions>
                        <Path x:Name="Arrow" Grid.Column="1"
                              Data="M 0 0 L 4 4 L 8 0 Z"
                              Fill="{DynamicResource PanelForeground}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>
                <ControlTemplate.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBackground}"/>
                    </Trigger>
                </ControlTemplate.Triggers>
            </ControlTemplate>

            <!-- ComboBox -->
            <Style TargetType="ComboBox">
                <Setter Property="Background" Value="{DynamicResource ButtonBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="MinHeight" Value="24"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBox">
                            <Grid>
                                <ToggleButton x:Name="PART_DropDownToggle"
                                              Template="{StaticResource ComboBoxToggleButtonTemplate}"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press"/>
                                <!-- Read-only display: shown when IsEditable=False (the trigger below
                                     hides this and shows PART_EditableTextBox instead when editable). -->
                                <ContentPresenter x:Name="ContentSite"
                                                  IsHitTestVisible="False"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                                  Margin="{TemplateBinding Padding}"
                                                  HorizontalAlignment="Left" VerticalAlignment="Center"
                                                  TextElement.Foreground="{DynamicResource PanelForeground}"/>
                                <!-- Editable mode: WPF requires a TextBox named PART_EditableTextBox.
                                     Without this, IsEditable=True ComboBoxes (e.g. the font-family
                                     pickers in Settings) render with no visible text. The TextBox's
                                     foreground/background here override the OS defaults so typed
                                     text is readable in dark mode. -->
                                <TextBox x:Name="PART_EditableTextBox"
                                         Visibility="Collapsed"
                                         Margin="{TemplateBinding Padding}"
                                         Padding="0"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Foreground="{DynamicResource PanelForeground}"
                                         CaretBrush="{DynamicResource PanelForeground}"
                                         SelectionBrush="{DynamicResource AccentBrush}"
                                         VerticalAlignment="Center"
                                         HorizontalAlignment="Stretch"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Focusable="True"/>
                                <Popup x:Name="PART_Popup"
                                       AllowsTransparency="True"
                                       Placement="Bottom"
                                       IsOpen="{TemplateBinding IsDropDownOpen}"
                                       PopupAnimation="Slide">
                                    <Border Background="{DynamicResource PanelBackground}"
                                            BorderBrush="{DynamicResource BorderBrushColor}"
                                            BorderThickness="1"
                                            MinWidth="{TemplateBinding ActualWidth}"
                                            MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <ScrollViewer SnapsToDevicePixels="True">
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <!-- Swap display ContentPresenter for the editable TextBox when
                                     IsEditable=True so user-typed text actually appears. -->
                                <Trigger Property="IsEditable" Value="True">
                                    <Setter TargetName="ContentSite" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ComboBoxItem -->
            <Style TargetType="ComboBoxItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ComboBoxItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    Padding="{TemplateBinding Padding}">
                                <ContentPresenter/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================
                 ScrollBar theming
                 ============================================================ -->

            <SolidColorBrush x:Key="ScrollBarTrack"  Color="#161616"/>
            <SolidColorBrush x:Key="ScrollBarThumb"  Color="#3A3A3A"/>
            <SolidColorBrush x:Key="ScrollBarThumbHover" Color="#555555"/>
            <SolidColorBrush x:Key="ScrollBarThumbActive" Color="#666666"/>

            <!-- Repeat buttons (track "page-up/page-down" hit zones) are invisible. -->
            <Style x:Key="ScrollBarPageButton" TargetType="RepeatButton">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border Background="Transparent"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Up/down (or left/right) line buttons at the ends of the bar. -->
            <Style x:Key="ScrollBarLineButton" TargetType="RepeatButton">
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="RepeatButton">
                            <Border x:Name="Bd" Background="{DynamicResource ScrollBarTrack}">
                                <Path x:Name="Arrow"
                                      HorizontalAlignment="Center" VerticalAlignment="Center"
                                      Fill="{DynamicResource MutedForeground}"
                                      Data="{TemplateBinding Tag}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ItemBackground}"/>
                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource PanelForeground}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- The draggable Thumb -->
            <Style x:Key="ScrollBarThumbStyle" TargetType="Thumb">
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="IsTabStop" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Border x:Name="Bd"
                                    Background="{DynamicResource ScrollBarThumb}"
                                    CornerRadius="3"
                                    Margin="2"/>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ScrollBarThumbHover}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ScrollBarThumbActive}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Vertical scrollbar template -->
            <ControlTemplate x:Key="VerticalScrollBarTemplate" TargetType="ScrollBar">
                <Grid Background="{DynamicResource ScrollBarTrack}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="14"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="14"/>
                    </Grid.RowDefinitions>
                    <RepeatButton Grid.Row="0" Style="{StaticResource ScrollBarLineButton}"
                                  Command="ScrollBar.LineUpCommand"
                                  Tag="M 0 4 L 8 4 L 4 0 Z"/>
                    <Track x:Name="PART_Track" Grid.Row="1" IsDirectionReversed="True">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageUpCommand"/>
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageDownCommand"/>
                        </Track.IncreaseRepeatButton>
                    </Track>
                    <RepeatButton Grid.Row="2" Style="{StaticResource ScrollBarLineButton}"
                                  Command="ScrollBar.LineDownCommand"
                                  Tag="M 0 0 L 8 0 L 4 4 Z"/>
                </Grid>
            </ControlTemplate>

            <!-- Horizontal scrollbar template -->
            <ControlTemplate x:Key="HorizontalScrollBarTemplate" TargetType="ScrollBar">
                <Grid Background="{DynamicResource ScrollBarTrack}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="14"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="14"/>
                    </Grid.ColumnDefinitions>
                    <RepeatButton Grid.Column="0" Style="{StaticResource ScrollBarLineButton}"
                                  Command="ScrollBar.LineLeftCommand"
                                  Tag="M 4 0 L 4 8 L 0 4 Z"/>
                    <Track x:Name="PART_Track" Grid.Column="1">
                        <Track.DecreaseRepeatButton>
                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageLeftCommand"/>
                        </Track.DecreaseRepeatButton>
                        <Track.Thumb>
                            <Thumb Style="{StaticResource ScrollBarThumbStyle}"/>
                        </Track.Thumb>
                        <Track.IncreaseRepeatButton>
                            <RepeatButton Style="{StaticResource ScrollBarPageButton}" Command="ScrollBar.PageRightCommand"/>
                        </Track.IncreaseRepeatButton>
                    </Track>
                    <RepeatButton Grid.Column="2" Style="{StaticResource ScrollBarLineButton}"
                                  Command="ScrollBar.LineRightCommand"
                                  Tag="M 0 0 L 0 8 L 4 4 Z"/>
                </Grid>
            </ControlTemplate>

            <Style TargetType="ScrollBar">
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Style.Triggers>
                    <Trigger Property="Orientation" Value="Horizontal">
                        <Setter Property="Width" Value="Auto"/>
                        <Setter Property="Height" Value="14"/>
                        <Setter Property="Template" Value="{StaticResource HorizontalScrollBarTemplate}"/>
                    </Trigger>
                    <Trigger Property="Orientation" Value="Vertical">
                        <Setter Property="Width" Value="14"/>
                        <Setter Property="Height" Value="Auto"/>
                        <Setter Property="Template" Value="{StaticResource VerticalScrollBarTemplate}"/>
                    </Trigger>
                </Style.Triggers>
            </Style>

            <!-- ============================================================
                 ContextMenu / MenuItem / Separator / ToolTip / GroupBox
                 (right-click menus and tooltips - default WPF templates
                 ignore our brushes and render Aero-white in dark mode)
                 ============================================================ -->

            <Style TargetType="ContextMenu">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="HasDropShadow" Value="True"/>
                <Setter Property="OverridesDefaultStyle" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ContextMenu">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    TextElement.Foreground="{DynamicResource PanelForeground}"
                                    SnapsToDevicePixels="True">
                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="MenuItem">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="BorderBrush" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="MenuItem">
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="22"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="14"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter x:Name="Icon" Grid.Column="0"
                                                      ContentSource="Icon"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Margin="4,0,0,0"/>
                                    <Path x:Name="GlyphPanel" Grid.Column="0"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"
                                          Data="M 0 5 L 3 9 L 9 0"
                                          Stroke="{DynamicResource PanelForeground}"
                                          StrokeThickness="2"/>
                                    <ContentPresenter Grid.Column="1"
                                                      ContentSource="Header"
                                                      RecognizesAccessKey="True"
                                                      VerticalAlignment="Center"
                                                      Margin="6,4,12,4"/>
                                    <TextBlock Grid.Column="2" Text="{TemplateBinding InputGestureText}"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource MutedForeground}"
                                               Margin="0,4,8,4"/>
                                    <Path x:Name="SubmenuArrow" Grid.Column="3"
                                          Visibility="Collapsed"
                                          VerticalAlignment="Center" HorizontalAlignment="Center"
                                          Data="M 0 0 L 4 4 L 0 8 Z"
                                          Fill="{DynamicResource PanelForeground}"/>
                                    <Popup x:Name="PART_Popup" Grid.Column="0"
                                           AllowsTransparency="True"
                                           Placement="Right"
                                           IsOpen="{TemplateBinding IsSubmenuOpen}"
                                           Focusable="False"
                                           PopupAnimation="Fade">
                                        <Border Background="{DynamicResource PanelBackground}"
                                                BorderBrush="{DynamicResource BorderBrushColor}"
                                                BorderThickness="1"
                                                TextElement.Foreground="{DynamicResource PanelForeground}"
                                                Margin="0,0,4,4">
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="6" ShadowDepth="2" Opacity="0.45" Color="Black"/>
                                            </Border.Effect>
                                            <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Cycle"/>
                                        </Border>
                                    </Popup>
                                </Grid>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="Role" Value="SubmenuHeader">
                                    <Setter TargetName="SubmenuArrow" Property="Visibility" Value="Visible"/>
                                </Trigger>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="GlyphPanel" Property="Visibility" Value="Visible"/>
                                    <Setter TargetName="Icon" Property="Visibility" Value="Collapsed"/>
                                </Trigger>
                                <Trigger Property="IsHighlighted" Value="True">
                                    <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="Separator">
                <Setter Property="Background" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="Margin" Value="6,3"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Separator">
                            <Border Background="{TemplateBinding Background}" Height="1" SnapsToDevicePixels="True"/>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="ToolTip">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="HasDropShadow" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToolTip">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Padding="{TemplateBinding Padding}"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter/>
                            </Border>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style TargetType="GroupBox">
                <Setter Property="Background" Value="{DynamicResource PanelBackground}"/>
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8"/>
            </Style>

            <Style TargetType="Label">
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
            </Style>

            <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
            </Style>

            <Style TargetType="RadioButton">
                <Setter Property="Foreground" Value="{DynamicResource PanelForeground}"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <!-- ============================================================
                 Keyed styles (referenced by Style="{StaticResource ...}")
                 ============================================================ -->

            <!-- ============================================================
                 3D PaneFrameBorder: raised "card" chrome around each
                 main pane (Source, Preview, Destinations). Outer border
                 + corner radius + drop shadow give a distinct lifted look
                 in the 3D theme. Theme-aware via DynamicResource so it
                 reads correctly in both Dark and Light.
                 ============================================================ -->
            <Style x:Key="PaneFrameBorder" TargetType="Border">
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrushColor}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="CornerRadius" Value="0"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Effect">
                    <Setter.Value>
                        <DropShadowEffect BlurRadius="10" ShadowDepth="2"
                                          Direction="270" Opacity="0.45"
                                          Color="Black"/>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================
                 3D ToolButton: raised gradient + bevel highlight/shadow.
                 Hover brightens the gradient. Pressed inverts ("pushed in").
                 ============================================================ -->
            <Style TargetType="Button" x:Key="ToolButton" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <!-- Outer border = subtle bevel -->
                                <Border x:Name="Outer"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3C3C3C" Offset="0"/>
                                            <GradientStop Color="#2A2A2A" Offset="0.5"/>
                                            <GradientStop Color="#1E1E1E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Inner top-left highlight (1px) -->
                                <Border x:Name="Highlight"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="#55FFFFFF"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <!-- Inner bottom-right shadow -->
                                <Border x:Name="Shadow"
                                        BorderThickness="0,0,1,1"
                                        BorderBrush="#66000000"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#4A4A4A" Offset="0"/>
                                                <GradientStop Color="#363636" Offset="0.5"/>
                                                <GradientStop Color="#262626" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#80FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1A1A1A" Offset="0"/>
                                                <GradientStop Color="#252525" Offset="0.5"/>
                                                <GradientStop Color="#383838" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <!-- Invert bevel: shadow on top, highlight on bottom -->
                                    <Setter TargetName="Highlight" Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#33FFFFFF"/>
                                    <Setter TargetName="Shadow" Property="BorderThickness" Value="1,1,0,0"/>
                                    <Setter TargetName="Shadow" Property="BorderBrush" Value="#80000000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================
                 Tinted ToolButton variants. Same 3D template as ToolButton
                 but the normal-state gradient is bound to {TemplateBinding
                 Background} so each variant only needs to set its own
                 Background brush. Hover/pressed use translucent overlays
                 (HoverOverlay / PressOverlay) instead of full gradient
                 swaps, so the tint stays consistent across all states.

                 Tints are intentionally subtle (gray with a hint of color)
                 so the toolbar still reads as one unified surface but
                 buttons group at a glance.
                 ============================================================ -->
            <Style TargetType="Button" x:Key="TintedToolButton" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Padding" Value="10,5"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="MinWidth" Value="80"/>
                <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <!-- Default tint = neutral gray (matches ToolButton). Variants override. -->
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#3C3C3C" Offset="0"/>
                            <GradientStop Color="#2A2A2A" Offset="0.5"/>
                            <GradientStop Color="#1E1E1E" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <Border x:Name="Outer"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3"
                                        SnapsToDevicePixels="True"/>
                                <!-- Hover overlay: translucent white wash (off by default). -->
                                <Border x:Name="HoverOverlay"
                                        Background="#22FFFFFF"
                                        CornerRadius="3"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <!-- Press overlay: translucent black wash (off by default). -->
                                <Border x:Name="PressOverlay"
                                        Background="#33000000"
                                        CornerRadius="3"
                                        Opacity="0"
                                        IsHitTestVisible="False"/>
                                <Border x:Name="Highlight"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="#55FFFFFF"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <Border x:Name="Shadow"
                                        BorderThickness="0,0,1,1"
                                        BorderBrush="#66000000"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#80FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="PressOverlay" Property="Opacity" Value="1"/>
                                    <Setter TargetName="Highlight" Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#33FFFFFF"/>
                                    <Setter TargetName="Shadow" Property="BorderThickness" Value="1,1,0,0"/>
                                    <Setter TargetName="Shadow" Property="BorderBrush" Value="#80000000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Navigation: Top, Bottom, position-related (warm amber tint). -->
            <Style x:Key="NavToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#423A2C" Offset="0"/>
                            <GradientStop Color="#322B22" Offset="0.5"/>
                            <GradientStop Color="#241F18" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Pane controls: ◀ ▶ ✕ in pane headers, Panes▾ (cool teal tint). -->
            <Style x:Key="PaneToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#2C3E42" Offset="0"/>
                            <GradientStop Color="#222F32" Offset="0.5"/>
                            <GradientStop Color="#182124" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Item actions: Skip, Rename, Tags (subtle green tint). -->
            <Style x:Key="ActionToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#2D3E2F" Offset="0"/>
                            <GradientStop Color="#222F23" Offset="0.5"/>
                            <GradientStop Color="#182118" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Destructive: Trash, close ✕ (red tint). -->
            <Style x:Key="DangerToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#42302E" Offset="0"/>
                            <GradientStop Color="#322422" Offset="0.5"/>
                            <GradientStop Color="#241A18" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary actions: Find duplicates, Undo, History (blue accent tint). -->
            <Style x:Key="PrimaryToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#2C3848" Offset="0"/>
                            <GradientStop Color="#222B38" Offset="0.5"/>
                            <GradientStop Color="#181F28" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Source location: Pick Source Folder, Recent▾ (purple tint). -->
            <Style x:Key="SourceToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#3A2E42" Offset="0"/>
                            <GradientStop Color="#2C2432" Offset="0.5"/>
                            <GradientStop Color="#1F1924" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Utility / reload: Refresh, Regen Thumbnails (warm bronze tint). -->
            <Style x:Key="UtilityToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#3E3528" Offset="0"/>
                            <GradientStop Color="#2F291F" Offset="0.5"/>
                            <GradientStop Color="#221E16" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Filter chip: small pill button used in the active-filters row.
                 Each chip shows the filter and a trailing ✕ to clear it. -->
            <Style x:Key="FilterChipButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="MinWidth" Value="0"/>
                <Setter Property="Padding" Value="8,2"/>
                <Setter Property="Margin" Value="0,0,4,4"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="ToolTip" Value="Click to clear this filter"/>
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#2C3848" Offset="0"/>
                            <GradientStop Color="#222B38" Offset="0.5"/>
                            <GradientStop Color="#181F28" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Info / meta: Settings, ?, About (cool slate tint). -->
            <Style x:Key="InfoToolButton" TargetType="Button" BasedOn="{StaticResource TintedToolButton}">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Color="#34383E" Offset="0"/>
                            <GradientStop Color="#272A30" Offset="0.5"/>
                            <GradientStop Color="#1B1D22" Offset="1"/>
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================
                 3D DestButton: accent-tinted gradient + drop shadow for a
                 raised, glossy look. Pressed removes shadow + inverts gradient.
                 ============================================================ -->
            <Style TargetType="Button" x:Key="DestButton" BasedOn="{StaticResource {x:Type Button}}">
                <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource AccentForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                <!-- Padding + MinHeight are DynamicResources so the Settings 'Destination
                     button size' preset (Compact/Normal/Large) can swap them at runtime. -->
                <Setter Property="Padding" Value="{DynamicResource DestButtonPadding}"/>
                <Setter Property="Margin" Value="4"/>
                <Setter Property="MinHeight" Value="{DynamicResource DestButtonMinHeight}"/>
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Grid>
                                <!-- Drop shadow halo (raised effect) -->
                                <Border x:Name="ShadowHalo"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="5"
                                        Margin="0,1,0,3">
                                    <Border.Effect>
                                        <DropShadowEffect Color="Black"
                                                          Direction="270"
                                                          ShadowDepth="2"
                                                          BlurRadius="5"
                                                          Opacity="0.45"/>
                                    </Border.Effect>
                                </Border>
                                <!-- Glossy accent gradient -->
                                <Border x:Name="Outer"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="5"
                                        Margin="0,1,0,3"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#55FFFFFF" Offset="0"/>
                                            <GradientStop Color="#00FFFFFF" Offset="0.5"/>
                                            <GradientStop Color="#33000000" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Top-left highlight bevel -->
                                <Border x:Name="Highlight"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="#66FFFFFF"
                                        CornerRadius="5"
                                        Margin="1,2,1,4"
                                        IsHitTestVisible="False"/>
                                <!-- Folder watermark: low-opacity vector folder icon
                                     sitting in the bottom-right corner of each dest
                                     button. Pure vector so it stays crisp at any DPI
                                     and tints automatically against any AccentBrush. -->
                                <Viewbox x:Name="FolderWatermark"
                                         Width="40" Height="40"
                                         HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                         Margin="0,0,8,6"
                                         IsHitTestVisible="False"
                                         Opacity="0.18">
                                    <Canvas Width="24" Height="24">
                                        <!-- Back tab -->
                                        <Path Data="M 2,5 L 9,5 L 11,7 L 22,7 L 22,9 L 2,9 Z"
                                              Fill="White"/>
                                        <!-- Body -->
                                        <Path Data="M 2,8 L 22,8 L 21,20 L 3,20 Z"
                                              Fill="White"/>
                                        <!-- Top edge highlight -->
                                        <Path Data="M 2,8 L 22,8" Stroke="White" StrokeThickness="0.6" Opacity="0.6"/>
                                    </Canvas>
                                </Viewbox>
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#80FFFFFF" Offset="0"/>
                                                <GradientStop Color="#10FFFFFF" Offset="0.5"/>
                                                <GradientStop Color="#22000000" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#99FFFFFF"/>
                                    <Setter TargetName="FolderWatermark" Property="Opacity" Value="0.30"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <!-- Remove drop shadow + push down 2px -->
                                    <Setter TargetName="ShadowHalo" Property="Effect" Value="{x:Null}"/>
                                    <Setter TargetName="ShadowHalo" Property="Margin" Value="0,3,0,1"/>
                                    <Setter TargetName="Outer" Property="Margin" Value="0,3,0,1"/>
                                    <Setter TargetName="Highlight" Property="Margin" Value="1,4,1,2"/>
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#44000000" Offset="0"/>
                                                <GradientStop Color="#10000000" Offset="0.5"/>
                                                <GradientStop Color="#33FFFFFF" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Highlight" Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#55FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
            <!-- ============================================================
                 3D ToolToggleButton: matches ToolButton's bevel + gradient.
                 Checked = "pushed in" (inverted gradient + shadow on top).
                 Used by LoopToggle and MuteToggle in the video controls.
                 ============================================================ -->
            <Style TargetType="ToggleButton" x:Key="ToolToggleButton">
                <Setter Property="Padding" Value="6,3"/>
                <Setter Property="Margin" Value="2"/>
                <Setter Property="Foreground" Value="{DynamicResource ButtonForeground}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource ButtonBorder}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ToggleButton">
                            <Grid>
                                <Border x:Name="Outer"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#3C3C3C" Offset="0"/>
                                            <GradientStop Color="#2A2A2A" Offset="0.5"/>
                                            <GradientStop Color="#1E1E1E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border x:Name="Highlight"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="#55FFFFFF"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <Border x:Name="Shadow"
                                        BorderThickness="0,0,1,1"
                                        BorderBrush="#66000000"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  RecognizesAccessKey="True"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#4A4A4A" Offset="0"/>
                                                <GradientStop Color="#363636" Offset="0.5"/>
                                                <GradientStop Color="#262626" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#80FFFFFF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1A1A1A" Offset="0"/>
                                                <GradientStop Color="#252525" Offset="0.5"/>
                                                <GradientStop Color="#383838" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Highlight" Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#33FFFFFF"/>
                                    <Setter TargetName="Shadow" Property="BorderThickness" Value="1,1,0,0"/>
                                    <Setter TargetName="Shadow" Property="BorderBrush" Value="#80000000"/>
                                </Trigger>
                                <!-- Checked = looks pushed in, with accent tint so it's clearly "on" -->
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="Outer" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1F2D3D" Offset="0"/>
                                                <GradientStop Color="#264563" Offset="0.5"/>
                                                <GradientStop Color="#33597F" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                    <Setter TargetName="Outer" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="Highlight" Property="BorderThickness" Value="0,0,1,1"/>
                                    <Setter TargetName="Highlight" Property="BorderBrush" Value="#33FFFFFF"/>
                                    <Setter TargetName="Shadow" Property="BorderThickness" Value="1,1,0,0"/>
                                    <Setter TargetName="Shadow" Property="BorderBrush" Value="#80000000"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================
                 3D Slider thumb: raised gradient pill with bevel.
                 Used inside ToolSlider's template.
                 ============================================================ -->
            <Style TargetType="Thumb" x:Key="ToolSliderThumb">
                <Setter Property="Width" Value="14"/>
                <Setter Property="Height" Value="18"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Thumb">
                            <Grid>
                                <Border x:Name="ThumbOuter"
                                        CornerRadius="3"
                                        BorderBrush="{DynamicResource ButtonBorder}"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#4A4A4A" Offset="0"/>
                                            <GradientStop Color="#2F2F2F" Offset="0.5"/>
                                            <GradientStop Color="#1E1E1E" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Border BorderThickness="1,1,0,0"
                                        BorderBrush="#66FFFFFF"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                                <Border BorderThickness="0,0,1,1"
                                        BorderBrush="#88000000"
                                        CornerRadius="3"
                                        Margin="1"
                                        IsHitTestVisible="False"/>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ThumbOuter" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                </Trigger>
                                <Trigger Property="IsDragging" Value="True">
                                    <Setter TargetName="ThumbOuter" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                    <Setter TargetName="ThumbOuter" Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                <GradientStop Color="#1A1A1A" Offset="0"/>
                                                <GradientStop Color="#2A2A2A" Offset="0.5"/>
                                                <GradientStop Color="#3C3C3C" Offset="1"/>
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- ============================================================
                 3D ToolSlider: inset "sunken" track + 3D thumb pill.
                 Used by VolumeSlider and VideoScrub. Horizontal only.
                 ============================================================ -->
            <Style TargetType="Slider" x:Key="ToolSlider">
                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                <Setter Property="MinHeight" Value="22"/>
                <Setter Property="VerticalAlignment" Value="Center"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Slider">
                            <Grid VerticalAlignment="Center">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>
                                <!-- Inset track: dark sunken channel with bevel reversed (shadow on top) -->
                                <Border Height="6"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        BorderBrush="#22000000"
                                        BorderThickness="1"
                                        SnapsToDevicePixels="True">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Color="#141414" Offset="0"/>
                                            <GradientStop Color="#1E1E1E" Offset="0.6"/>
                                            <GradientStop Color="#2A2A2A" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Inner 1px shadow on top + highlight on bottom (sunken bevel) -->
                                <Border Height="6"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        BorderThickness="1,1,0,0"
                                        BorderBrush="#88000000"
                                        IsHitTestVisible="False"/>
                                <Border Height="6"
                                        VerticalAlignment="Center"
                                        CornerRadius="3"
                                        BorderThickness="0,0,1,1"
                                        BorderBrush="#22FFFFFF"
                                        IsHitTestVisible="False"/>
                                <Track x:Name="PART_Track">
                                    <Track.DecreaseRepeatButton>
                                        <RepeatButton Command="Slider.DecreaseLarge" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <!-- Filled portion = accent gradient -->
                                                    <Border Height="6" CornerRadius="3" SnapsToDevicePixels="True">
                                                        <Border.Background>
                                                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                                <GradientStop Color="#4FA3FF" Offset="0"/>
                                                                <GradientStop Color="#2D7FD9" Offset="1"/>
                                                            </LinearGradientBrush>
                                                        </Border.Background>
                                                    </Border>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.DecreaseRepeatButton>
                                    <Track.IncreaseRepeatButton>
                                        <RepeatButton Command="Slider.IncreaseLarge" Focusable="False">
                                            <RepeatButton.Template>
                                                <ControlTemplate TargetType="RepeatButton">
                                                    <Border Background="Transparent"/>
                                                </ControlTemplate>
                                            </RepeatButton.Template>
                                        </RepeatButton>
                                    </Track.IncreaseRepeatButton>
                                    <Track.Thumb>
                                        <Thumb Style="{StaticResource ToolSliderThumb}"/>
                                    </Track.Thumb>
                                </Track>
                            </Grid>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
