<Window x:Class="MediaSort.Views.BatchRenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Batch Rename"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="520" Width="640"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        MinHeight="420" MinWidth="540">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Batch Rename" FontWeight="Bold" FontSize="14" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1" x:Name="HeaderText"
                   Foreground="{DynamicResource MutedForeground}" Margin="0,0,0,10"/>

        <Grid Grid.Row="2" Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="60"/>
                <ColumnDefinition Width="80"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Name pattern:" VerticalAlignment="Center"/>
            <TextBox Grid.Column="1" x:Name="PatternBox" Padding="6"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource PanelForeground}"
                     BorderBrush="{DynamicResource ButtonBorder}"
                     TextChanged="Pattern_Changed"/>
            <TextBlock Grid.Column="2" Text="Start:" VerticalAlignment="Center" Margin="10,0,4,0"/>
            <TextBox Grid.Column="3" x:Name="StartBox" Padding="6"
                     Background="{DynamicResource InputBackground}"
                     Foreground="{DynamicResource PanelForeground}"
                     BorderBrush="{DynamicResource ButtonBorder}"
                     Text="1" TextChanged="Pattern_Changed"/>
        </Grid>

        <TextBlock Grid.Row="3" Margin="0,4,0,8" Foreground="{DynamicResource MutedForeground}" FontSize="11"
                   TextWrapping="Wrap">
            Tokens: <Run FontWeight="Bold" Text="{}{name}"/> original name &#x2022;
            <Run FontWeight="Bold" Text="{}{n}"/> counter (use <Run FontWeight="Bold" Text="{}{n:000}"/> for zero-padding) &#x2022;
            <Run FontWeight="Bold" Text="{}{date:yyyy-MM-dd}"/> file date &#x2022;
            <Run FontWeight="Bold" Text="{}{ext}"/> extension
        </TextBlock>

        <Grid Grid.Row="4" Margin="0,2,0,4">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="110"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <CheckBox Grid.Column="0" x:Name="LowercaseCheck" Content="lowercase"
                      VerticalAlignment="Center" Click="Pattern_Changed"
                      Foreground="{DynamicResource PanelForeground}"/>
            <CheckBox Grid.Column="1" x:Name="ReplaceSpacesCheck" Content="replace spaces with _"
                      VerticalAlignment="Center" Click="Pattern_Changed"
                      Foreground="{DynamicResource PanelForeground}"/>
        </Grid>

        <TextBlock Grid.Row="5" Text="Preview:" Margin="0,8,0,4" FontWeight="Bold"/>

        <ListView Grid.Row="6" x:Name="PreviewList"
                  Background="{DynamicResource InputBackground}"
                  Foreground="{DynamicResource PanelForeground}"
                  BorderBrush="{DynamicResource ButtonBorder}">
            <ListView.View>
                <GridView>
                    <GridViewColumn Width="270" Header="Original" DisplayMemberBinding="{Binding Original}"/>
                    <GridViewColumn Width="270" Header="New" DisplayMemberBinding="{Binding NewName}"/>
                    <GridViewColumn Width="60" Header="Status" DisplayMemberBinding="{Binding Status}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="7" x:Name="ErrorText" Foreground="#E04F4F" FontSize="11"
                   TextWrapping="Wrap" Margin="0,6,0,0"/>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Cancel" Width="90" Margin="4,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Rename All" Width="110" Margin="4,0" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
