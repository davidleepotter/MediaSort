<Window x:Class="MediaSort.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirm"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        SizeToContent="WidthAndHeight"
        MinWidth="360" MaxWidth="520"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
    <Grid Margin="18,16,18,14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" x:Name="HeadingText"
                   FontWeight="Bold" FontSize="14"
                   Foreground="{DynamicResource PanelForeground}"
                   Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" x:Name="MessageText"
                   TextWrapping="Wrap"
                   Foreground="{DynamicResource PanelForeground}"
                   Margin="0,0,0,16"
                   MaxWidth="480"/>

        <CheckBox Grid.Row="2" x:Name="DontAskAgainCheck"
                  Visibility="Collapsed"
                  Content="Don't ask again"
                  Foreground="{DynamicResource PanelForeground}"
                  Margin="0,0,0,12"/>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="CancelButton" Content="Cancel" MinWidth="90" Padding="14,4" Margin="4,0"
                    IsCancel="True" Click="Cancel_Click"/>
            <Button x:Name="OkButton" Content="OK" MinWidth="90" Padding="14,4" Margin="4,0"
                    IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
