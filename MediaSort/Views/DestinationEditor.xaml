<Window x:Class="MediaSort.Views.DestinationEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Destination"
        Height="280" Width="520"
        Background="#1E1E1E"
        Foreground="#EEE"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="100"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"/>
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="NameBox" Margin="0,0,0,8" Padding="4" Background="#2A2A2A" Foreground="#EEE" BorderBrush="#444"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Folder" VerticalAlignment="Center"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="FolderBox" Margin="0,0,4,8" Padding="4" Background="#2A2A2A" Foreground="#EEE" BorderBrush="#444"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Style="{StaticResource ToolButton}" Click="Browse_Click" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Hotkey" VerticalAlignment="Center"/>
        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="HotkeyBox" IsReadOnly="True" Margin="0,0,0,8" Padding="4" Background="#2A2A2A" Foreground="#EEE" BorderBrush="#444"
                 PreviewKeyDown="HotkeyBox_PreviewKeyDown" Text="(click here, then press a key)"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="3" FontSize="11" Opacity="0.7"
                   Text="Tip: hold Ctrl, Alt, or Shift while pressing the key to set a modified shortcut. Press Backspace or Delete to clear."
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolButton}" Click="Cancel_Click" Width="90"/>
            <Button Content="OK" Style="{StaticResource ToolButton}" Click="Ok_Click" Width="90" Margin="6,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
