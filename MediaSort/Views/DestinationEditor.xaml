<Window x:Class="MediaSort.Views.DestinationEditor"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Edit Destination"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="460" Width="560"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Name" VerticalAlignment="Center"
                   Foreground="{DynamicResource PanelForeground}"/>
        <TextBox Grid.Row="0" Grid.Column="1" Grid.ColumnSpan="2" x:Name="NameBox"
                 Margin="0,0,0,8" Padding="4"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource ButtonBorder}"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Folder" VerticalAlignment="Center"
                   Foreground="{DynamicResource PanelForeground}"/>
        <TextBox Grid.Row="1" Grid.Column="1" x:Name="FolderBox"
                 Margin="0,0,4,8" Padding="4"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource ButtonBorder}"/>
        <Button Grid.Row="1" Grid.Column="2" Content="Browse..." Style="{StaticResource ToolButton}"
                Click="Browse_Click" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Hotkey" VerticalAlignment="Center"
                   Foreground="{DynamicResource PanelForeground}"/>
        <TextBox Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="2" x:Name="HotkeyBox"
                 IsReadOnly="True" Margin="0,0,0,8" Padding="4"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource ButtonBorder}"
                 PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                 Text="(click here, then press a key)"/>

        <TextBlock Grid.Row="3" Grid.ColumnSpan="3" FontSize="11"
                   Foreground="{DynamicResource MutedForeground}"
                   Text="Tip: hold Ctrl, Alt, or Shift while pressing the key to set a modified shortcut. Press Backspace or Delete to clear."
                   TextWrapping="Wrap" Margin="0,0,0,12"/>

        <TextBlock Grid.Row="4" Grid.Column="0" Text="Accept kind" VerticalAlignment="Center"
                   Foreground="{DynamicResource PanelForeground}"/>
        <ComboBox Grid.Row="4" Grid.Column="1" Grid.ColumnSpan="2" x:Name="KindFilterCombo"
                  Margin="0,0,0,8">
            <ComboBoxItem Content="Any (images and videos)"/>
            <ComboBoxItem Content="Images only"/>
            <ComboBoxItem Content="Videos only"/>
        </ComboBox>

        <TextBlock Grid.Row="5" Grid.Column="0" Text="Subfolder" VerticalAlignment="Center"
                   Foreground="{DynamicResource PanelForeground}"/>
        <TextBox Grid.Row="5" Grid.Column="1" Grid.ColumnSpan="2" x:Name="SubfolderBox"
                 Margin="0,0,0,4" Padding="4"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource ButtonBorder}"/>
        <TextBlock Grid.Row="6" Grid.ColumnSpan="3" FontSize="11"
                   Foreground="{DynamicResource MutedForeground}"
                   Text="Optional. Tokens: {date:yyyy-MM}, {kind}, {ext}. Example: Photos/{date:yyyy-MM}"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="7" Grid.Column="0" Text="Rename" VerticalAlignment="Center"
                   Foreground="{DynamicResource PanelForeground}"/>
        <TextBox Grid.Row="7" Grid.Column="1" Grid.ColumnSpan="2" x:Name="RenameBox"
                 Margin="0,0,0,4" Padding="4"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource ButtonBorder}"/>
        <TextBlock Grid.Row="8" Grid.ColumnSpan="3" FontSize="11"
                   Foreground="{DynamicResource MutedForeground}"
                   Text="Optional. Tokens: {name}, {ext}, {date:yyyy-MM-dd}. Example: {date:yyyy-MM-dd}_{name}{ext}"
                   TextWrapping="Wrap" Margin="0,0,0,8"/>

        <StackPanel Grid.Row="9" Grid.ColumnSpan="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolButton}" Click="Cancel_Click" Width="90"/>
            <Button Content="OK" Style="{StaticResource ToolButton}" Click="Ok_Click" Width="90" Margin="6,0,0,0"/>
        </StackPanel>
    </Grid>
</Window>
