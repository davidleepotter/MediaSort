<Window x:Class="MediaSort.Views.DuplicatesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:MediaSort.Models"
        Title="Find Duplicates"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="720" Width="1080"
        MinHeight="500" MinWidth="780"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="14">

        <!-- Header strip: summary + bulk-action chooser -->
        <Border DockPanel.Dock="Top" Padding="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0">
                    <TextBlock x:Name="SummaryText" FontSize="15" FontWeight="SemiBold"
                               Text="Looking for duplicates…"/>
                    <TextBlock x:Name="HintText" Margin="0,4,0,0" Opacity="0.75"
                               TextWrapping="Wrap"
                               Text="The largest copy in each group is highlighted in green. Click a different thumbnail to keep it instead. Files in orange will be moved when you apply."/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Move duplicates to:" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <ComboBox x:Name="DestCombo" Width="240"
                              DisplayMemberPath="DisplayLabel"
                              VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Footer with action buttons -->
        <Border DockPanel.Dock="Bottom" Padding="0,12,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" VerticalAlignment="Center"
                           Opacity="0.8"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="KeepLargestButton" Content="Pick largest in every group"
                            Width="200" Margin="0,0,8,0" Click="KeepLargest_Click"/>
                    <Button x:Name="ApplyButton" Content="Move duplicates" Width="150"
                            Margin="0,0,8,0" Click="Apply_Click" IsDefault="True"/>
                    <Button Content="Close" Width="90" IsCancel="True" Click="Close_Click"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Scrollable list of duplicate groups. Each group is a horizontal strip
             of thumbnails; clicking a thumb sets it as the "keep" winner.
             Ribbon colours are refreshed imperatively when Keep changes. -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <ItemsControl x:Name="GroupsList">
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type models:DuplicateGroup}">
                        <Border BorderBrush="{DynamicResource BorderBrushColor}"
                                BorderThickness="0,0,0,1"
                                Padding="0,10,0,12" Margin="0,0,0,4">
                            <DockPanel>
                                <TextBlock DockPanel.Dock="Top"
                                           Text="{Binding HeaderText}"
                                           FontWeight="SemiBold" Margin="0,0,0,6"
                                           TextTrimming="CharacterEllipsis"/>
                                <ItemsControl ItemsSource="{Binding Members}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel Orientation="Horizontal"/>
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:MediaItem}">
                                            <!-- A clickable thumbnail card. The Tag carries the bound
                                                 MediaItem so the click handler can find it without
                                                 spelunking the visual tree. -->
                                            <Button Click="ThumbButton_Click"
                                                    Tag="{Binding}"
                                                    Margin="4" Padding="0"
                                                    Background="Transparent" BorderThickness="0"
                                                    Cursor="Hand"
                                                    ToolTip="{Binding FullPath}">
                                                <Border x:Name="Frame" Width="160" Height="200"
                                                        BorderBrush="{DynamicResource BorderBrushColor}"
                                                        BorderThickness="2"
                                                        UseLayoutRounding="True"
                                                        SnapsToDevicePixels="True">
                                                    <Grid>
                                                        <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                                               UseLayoutRounding="True" SnapsToDevicePixels="True"/>
                                                        <!-- Status ribbon: filled in by code-behind RefreshRibbons. -->
                                                        <Border x:Name="StatusRibbon"
                                                                VerticalAlignment="Top"
                                                                HorizontalAlignment="Stretch"
                                                                Height="22"
                                                                Visibility="Collapsed">
                                                            <TextBlock x:Name="StatusBadge"
                                                                       VerticalAlignment="Center"
                                                                       HorizontalAlignment="Center"
                                                                       FontWeight="Bold" Foreground="White"
                                                                       FontSize="11"/>
                                                        </Border>
                                                        <!-- Filename + dimensions strip. -->
                                                        <Border VerticalAlignment="Bottom" Height="40"
                                                                Background="#CC000000" Padding="6,2">
                                                            <StackPanel>
                                                                <TextBlock Text="{Binding FileName}"
                                                                           Foreground="White"
                                                                           FontSize="11"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock FontSize="10" Foreground="#DDD"
                                                                           TextTrimming="CharacterEllipsis">
                                                                    <Run Text="{Binding PixelWidth, Mode=OneWay}"/>
                                                                    <Run Text="×"/>
                                                                    <Run Text="{Binding PixelHeight, Mode=OneWay}"/>
                                                                    <Run Text="  ·  "/>
                                                                    <Run Text="{Binding SizeDisplay, Mode=OneWay}"/>
                                                                </TextBlock>
                                                            </StackPanel>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </DockPanel>
</Window>
