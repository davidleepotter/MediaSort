<Window x:Class="MediaSort.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Move history"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="540" Width="780"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Move history" FontSize="16" FontWeight="Bold"
                   Foreground="{DynamicResource PanelForeground}" Margin="0,0,0,4"/>
        <TextBlock Grid.Row="1"
                   Text="Most-recent batch is on top. Pick any batch to undo it; older entries below stay intact. Recycle Bin items must be restored from Windows."
                   Foreground="{DynamicResource MutedForeground}"
                   FontSize="11" TextWrapping="Wrap" Margin="0,0,0,10"/>

        <ListView Grid.Row="2" x:Name="BatchList" SelectionMode="Single"
                  Background="{DynamicResource PanelBackground}"
                  Foreground="{DynamicResource PanelForeground}"
                  BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1"
                  SelectionChanged="BatchList_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="When" Width="150"
                                    DisplayMemberBinding="{Binding WhenText}"/>
                    <GridViewColumn Header="Action" Width="80"
                                    DisplayMemberBinding="{Binding ActionText}"/>
                    <GridViewColumn Header="Files" Width="60"
                                    DisplayMemberBinding="{Binding Count}"/>
                    <GridViewColumn Header="Summary" Width="420"
                                    DisplayMemberBinding="{Binding Summary}"/>
                </GridView>
            </ListView.View>
        </ListView>

        <TextBlock Grid.Row="3" Text="Files in selected batch" FontWeight="Bold"
                   Foreground="{DynamicResource MutedForeground}" Margin="0,12,0,4"/>

        <ListBox Grid.Row="4" x:Name="DetailList" Height="120"
                 Background="{DynamicResource PanelBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Margin="2">
                        <TextBlock Text="{Binding NewPath}" FontFamily="Consolas" FontSize="11"
                                   Foreground="{DynamicResource PanelForeground}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding OriginalPath}" FontFamily="Consolas" FontSize="10"
                                   Foreground="{DynamicResource MutedForeground}"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <DockPanel Grid.Row="5" Margin="0,12,0,0" LastChildFill="False">
            <Button DockPanel.Dock="Left" Content="Open Log File"
                    Style="{StaticResource UtilityToolButton}" Click="OpenLog_Click"
                    MinWidth="110" Padding="14,4"
                    ToolTip="Opens the CSV move-history log in Notepad."/>
            <Button DockPanel.Dock="Left" x:Name="ClearHistoryButton"
                    Content="Clear History"
                    Style="{StaticResource DangerToolButton}" Click="ClearHistory_Click"
                    MinWidth="110" Padding="14,4" Margin="6,0,0,0"
                    ToolTip="Drop all undo batches from memory. The CSV audit log on disk is preserved."/>
            <Button DockPanel.Dock="Right" Content="Close"
                    Style="{StaticResource ToolButton}" Click="Close_Click"
                    MinWidth="90" Padding="14,4" Margin="6,0,0,0"
                    IsCancel="True"/>
            <Button DockPanel.Dock="Right" x:Name="UndoSelectedButton"
                    Content="Undo Selected Batch"
                    Style="{StaticResource PrimaryToolButton}" Click="UndoSelected_Click"
                    MinWidth="160" Padding="14,4" IsEnabled="False"
                    ToolTip="Restore every file in the selected batch back to its source folder."/>
        </DockPanel>
    </Grid>
</Window>
