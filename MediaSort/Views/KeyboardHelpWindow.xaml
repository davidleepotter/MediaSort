<Window x:Class="MediaSort.Views.KeyboardHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaSort Help"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="640" Width="720"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="MediaSort Help" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" Opacity="0.75"
                   Text="Quick reference for keyboard shortcuts and how the destination flow works."/>

        <Button DockPanel.Dock="Bottom" Content="Close" Width="90" HorizontalAlignment="Right"
                IsCancel="True" Click="Close_Click" Margin="0,12,0,0"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Section nav -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <RadioButton x:Name="NavShortcuts" Content="Keyboard Shortcuts"
                             GroupName="HelpSection" IsChecked="True"
                             Checked="NavShortcuts_Checked"
                             Padding="10,8" Margin="0,0,0,4"
                             HorizontalContentAlignment="Left"
                             FontWeight="SemiBold"/>
                <RadioButton x:Name="NavFlow" Content="Destinations &amp; Flow"
                             GroupName="HelpSection"
                             Checked="NavFlow_Checked"
                             Padding="10,8" Margin="0,0,0,4"
                             HorizontalContentAlignment="Left"
                             FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Section content -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="1" CornerRadius="6" Padding="14"
                    Background="{DynamicResource PanelBackground}">

                <Grid>
                    <!-- ========== KEYBOARD SHORTCUTS (data-driven, searchable) ========== -->
                    <DockPanel x:Name="ShortcutsView">
                        <!-- Filter row + result count -->
                        <Grid DockPanel.Dock="Top" Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" x:Name="FilterBox" Padding="6,4"
                                     Background="{DynamicResource InputBackground}"
                                     Foreground="{DynamicResource PanelForeground}"
                                     BorderBrush="{DynamicResource ButtonBorder}"
                                     TextChanged="FilterBox_TextChanged"
                                     PreviewKeyDown="FilterBox_PreviewKeyDown"
                                     ToolTip="Filter by key, action, or category. Esc to clear."/>
                            <TextBlock Grid.Column="1" x:Name="FilterPlaceholder" Text="Type to filter…"
                                       IsHitTestVisible="False" VerticalAlignment="Center"
                                       Margin="10,0,0,0" Opacity="0.55"
                                       Foreground="{DynamicResource MutedForeground}"/>
                            <Button Grid.Column="2" Content="Copy as Markdown" Style="{StaticResource UtilityToolButton}"
                                    Click="CopyMarkdown_Click" Margin="8,0,0,0"
                                    ToolTip="Copy the visible shortcut list to the clipboard as a Markdown table"/>
                        </Grid>
                        <TextBlock DockPanel.Dock="Top" x:Name="FilterCountText" Margin="0,0,0,8"
                                   FontSize="11" Foreground="{DynamicResource MutedForeground}"/>

                        <!-- Grouped, filtered list of shortcut entries. Bound from code-behind. -->
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="ShortcutsList">
                                <ItemsControl.GroupStyle>
                                    <GroupStyle>
                                        <GroupStyle.HeaderTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                           Margin="0,10,0,4"
                                                           Foreground="{DynamicResource PanelForeground}"/>
                                            </DataTemplate>
                                        </GroupStyle.HeaderTemplate>
                                    </GroupStyle>
                                </ItemsControl.GroupStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="12,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="{Binding KeyDisplay}"
                                                       FontFamily="Consolas" TextWrapping="Wrap"
                                                       Foreground="{DynamicResource PanelForeground}"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Description}"
                                                       TextWrapping="Wrap"
                                                       Foreground="{DynamicResource PanelForeground}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>

                    <!-- ========== DESTINATIONS & FLOW ========== -->
                    <ScrollViewer x:Name="FlowView" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="The basic flow" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                <Run Text="MediaSort is built around a one-handed sorting flow:"/>
                                <LineBreak/>
                                <Run Text="  1. "/><Run Text="Pick a source folder" FontWeight="SemiBold"/><Run Text=" — the list shows every photo and video found."/>
                                <LineBreak/>
                                <Run Text="  2. "/><Run Text="Select an item" FontWeight="SemiBold"/><Run Text=" — preview shows in the right pane."/>
                                <LineBreak/>
                                <Run Text="  3. "/><Run Text="Press a destination hotkey" FontWeight="SemiBold"/><Run Text=" — the file flies to that destination button."/>
                                <LineBreak/>
                                <Run Text="  4. "/><Run Text="Selection auto-advances" FontWeight="SemiBold"/><Run Text=" to the next item, so you can keep sorting without touching the mouse."/>
                            </TextBlock>

                            <TextBlock Text="What is a destination?" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="A destination is a saved target folder shown as a button in the right-hand panel. Each destination has a name, a folder path, an optional hotkey, and an optional kind filter (Image-only or Video-only). Add as many as you need — common patterns are 'Keep', 'Archive', 'Edit later', 'Family', 'Trash to review'."/>

                            <TextBlock Text="Destination row controls" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <Grid Margin="12,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="110"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Click button" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"
                                           Text="Send the currently-selected item(s) to this destination. Same as pressing the hotkey."/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+Click" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Open this destination folder in File Explorer (no move)."/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Right-click" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Open the destination menu: Open folder in Explorer, Use as source folder, Move up / Move down (also changes the position-based hotkey), Edit destination, Remove destination."/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="⋮⋮ handle" FontWeight="SemiBold" VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Click and hold the dotted handle on the left, then drag up or down to reorder."/>
                            </Grid>

                            <TextBlock Text="Hotkeys for destinations" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                Text="Each destination shows its hotkey in the corner of its button. Two flavors:"/>
                            <Grid Margin="12,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Position keys 1–9, 0" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"
                                           Text="The first 10 destinations are reachable by pressing the matching number key on the top row OR the numeric keypad."/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Custom letter" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap"
                                           Text="Set a single letter in the destination editor for a memorable shortcut (e.g. K for Keep, A for Archive)."/>
                            </Grid>

                            <TextBlock Text="Move vs. Copy" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="The toolbar Action selector controls what happens when a hotkey or destination button fires. Move removes the file from the source folder; Copy leaves the original in place. The setting applies equally to button clicks and hotkey presses."/>

                            <TextBlock Text="Multi-select" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Hold Shift or Ctrl to select multiple items, then press a destination hotkey or click its button — every selected file is sent in one batch. The source-to-destination animation now plays for each item, fanning out to make the action visible."/>

                            <TextBlock Text="Kind filter" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="A destination can be restricted to Image-only or Video-only. If you send a mixed selection, only matching files go through and the status bar reports how many were skipped."/>

                            <TextBlock Text="Conflicts" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="If a file with the same name already exists in the destination, MediaSort follows the conflict policy from Settings (Prompt, Skip, Overwrite, or Rename). When prompted you can apply your choice to the rest of the batch."/>

                            <TextBlock Text="Undo" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Ctrl+Z reverses the last action — including a multi-file batch. Items are returned to their original folder and selection is restored."/>

                            <TextBlock Text="Find Duplicates" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="The Find Duplicates toolbar button hashes every image in the current source folder using a perceptual algorithm (dHash) so visually similar shots are grouped even if filenames or sizes differ. Matches are tagged with a red DUP badge in the list and an interactive review dialog opens to keep / delete / move duplicates. Adjust the match threshold in Settings — strict (0–2) for near-identical only, loose (8+) to catch more variation."/>

                            <TextBlock Text="Rotating images" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Right-click any image → Rotate to turn it 90° clockwise, 90° counter-clockwise, or 180°. The file is rewritten in place (JPEG quality 95, lossless for PNG/BMP/GIF/TIFF) and the thumbnail/preview refreshes automatically. Multi-select first to rotate a batch — a confirmation dialog appears."/>

                            <TextBlock Text="Video preview controls" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Videos play in the preview pane with play/pause, stop, loop, mute, volume, and a scrub slider. Audio is enabled by default — press M (or click the mute button) to toggle silence. The volume slider remembers your last level across sessions."/>

                            <TextBlock Text="Supported formats" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Standard photos (JPG/PNG/BMP/GIF/TIFF/WEBP), HEIC/HEIF, and common camera RAW formats are detected and thumbnailed via the Windows Shell. Videos rely on the bundled LibVLC engine and cover essentially anything VLC can play."/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
