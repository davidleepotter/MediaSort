<Window x:Class="MediaSort.Views.KeyboardHelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaSort Help"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="640" Width="720"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <TextBlock DockPanel.Dock="Top" Text="MediaSort Help" FontSize="20" FontWeight="Bold" Margin="0,0,0,4"/>
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,12" Opacity="0.75"
                   Text="Quick reference for keyboard shortcuts and how the destination flow works."/>

        <Button DockPanel.Dock="Bottom" Content="Close" Width="90" HorizontalAlignment="Right"
                IsCancel="True" Click="Close_Click" Margin="0,12,0,0"/>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="170"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Section nav -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                <RadioButton x:Name="NavShortcuts" Content="Keyboard Shortcuts"
                             GroupName="HelpSection" IsChecked="True"
                             Checked="NavShortcuts_Checked"
                             Padding="10,8" Margin="0,0,0,4"
                             HorizontalContentAlignment="Left"
                             FontWeight="SemiBold"/>
                <RadioButton x:Name="NavFlow" Content="Destinations &amp; Flow"
                             GroupName="HelpSection"
                             Checked="NavFlow_Checked"
                             Padding="10,8" Margin="0,0,0,4"
                             HorizontalContentAlignment="Left"
                             FontWeight="SemiBold"/>
            </StackPanel>

            <!-- Section content -->
            <Border Grid.Column="1"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="1" CornerRadius="6" Padding="14"
                    Background="{DynamicResource PanelBackground}">

                <Grid>
                    <!-- ========== KEYBOARD SHORTCUTS ========== -->
                    <ScrollViewer x:Name="ShortcutsView" VerticalScrollBarVisibility="Auto">
                        <StackPanel>
                            <TextBlock Text="Navigation" FontWeight="Bold" Margin="0,0,0,4"/>
                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="↑ / ↓ / ← / →" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Move selection in the source list"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Home / End" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Jump to first/last item"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Page Up/Down" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Page through the list"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="Ctrl+F" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Focus the search box"/>
                            </Grid>

                            <TextBlock Text="Sorting / moving" FontWeight="Bold" Margin="0,12,0,4"/>
                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Destination hotkey" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Move selected item(s) to that destination"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="." FontFamily="Consolas"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Repeat last destination (send selection to the last destination you used)"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="F" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Toggle star/favorite on the current selection (persists across sessions)"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="F2" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Rename the selected file (single selection only)"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+Z" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Undo last move (or batch)"/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="N" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" Text="Skip — advance to next without moving"/>
                                <TextBlock Grid.Row="6" Grid.Column="0" Text="Delete" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="6" Grid.Column="1" Text="Send selected item(s) to Recycle Bin"/>
                                <TextBlock Grid.Row="7" Grid.Column="0" Text="Ctrl+A" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="7" Grid.Column="1" Text="Select all visible items"/>
                            </Grid>

                            <TextBlock Text="View / preview" FontWeight="Bold" Margin="0,12,0,4"/>
                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Space" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Play/pause video preview"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Mouse wheel" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Zoom image preview"/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="Click + drag" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" Text="Pan zoomed image"/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="0" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" Text="Reset image zoom to fit"/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="? / F1" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" Text="Show this help"/>
                            </Grid>

                            <TextBlock Text="Other" FontWeight="Bold" Margin="0,12,0,4"/>
                            <Grid Margin="12,0">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+," FontFamily="Consolas"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Open Settings"/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="F5" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="Refresh source list"/>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>

                    <!-- ========== DESTINATIONS & FLOW ========== -->
                    <ScrollViewer x:Name="FlowView" VerticalScrollBarVisibility="Auto" Visibility="Collapsed">
                        <StackPanel>

                            <TextBlock Text="The basic flow" FontWeight="Bold" FontSize="14" Margin="0,0,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10">
                                <Run Text="MediaSort is built around a one-handed sorting flow:"/>
                                <LineBreak/>
                                <Run Text="  1. "/><Run Text="Pick a source folder" FontWeight="SemiBold"/><Run Text=" — the list shows every photo and video found."/>
                                <LineBreak/>
                                <Run Text="  2. "/><Run Text="Select an item" FontWeight="SemiBold"/><Run Text=" — preview shows in the right pane."/>
                                <LineBreak/>
                                <Run Text="  3. "/><Run Text="Press a destination hotkey" FontWeight="SemiBold"/><Run Text=" — the file flies to that destination button."/>
                                <LineBreak/>
                                <Run Text="  4. "/><Run Text="Selection auto-advances" FontWeight="SemiBold"/><Run Text=" to the next item, so you can keep sorting without touching the mouse."/>
                            </TextBlock>

                            <TextBlock Text="What is a destination?" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="A destination is a saved target folder shown as a button in the right-hand panel. Each destination has a name, a folder path, an optional hotkey, and an optional kind filter (Image-only or Video-only). Add as many as you need — common patterns are 'Keep', 'Archive', 'Edit later', 'Family', 'Trash to review'."/>

                            <TextBlock Text="Each destination row has these buttons" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <Grid Margin="12,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="60"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                    <RowDefinition/><RowDefinition/><RowDefinition/>
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="↑ / ↓" FontFamily="Consolas" VerticalAlignment="Top"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap" Text="Reorder this destination in the list (also changes its position-based hotkey)."/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="📂"  VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Open the destination folder in File Explorer."/>
                                <TextBlock Grid.Row="2" Grid.Column="0" Text="➜"  VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="2" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Use this destination as the new source folder — handy for drilling into a folder you just sorted into."/>
                                <TextBlock Grid.Row="3" Grid.Column="0" Text="✎"  VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="3" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Edit this destination — name, folder, hotkey, kind filter."/>
                                <TextBlock Grid.Row="4" Grid.Column="0" Text="✕"  VerticalAlignment="Top" Margin="0,4,0,0"/>
                                <TextBlock Grid.Row="4" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Remove this destination (does not delete the folder on disk)."/>
                                <TextBlock Grid.Row="5" Grid.Column="0" Text="(body)"  VerticalAlignment="Top" Margin="0,4,0,0" Opacity="0.7"/>
                                <TextBlock Grid.Row="5" Grid.Column="1" TextWrapping="Wrap" Margin="0,4,0,0"
                                           Text="Click the main button face to send the currently-selected item(s) here. Same as pressing the hotkey."/>
                            </Grid>

                            <TextBlock Text="Hotkeys for destinations" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,6"
                                Text="Each destination shows its hotkey in the corner of its button. Two flavors:"/>
                            <Grid Margin="12,0,0,10">
                                <Grid.ColumnDefinitions><ColumnDefinition Width="160"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Position keys 1–9, 0" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" TextWrapping="Wrap"
                                           Text="The first 10 destinations are reachable by pressing the matching number key on the top row OR the numeric keypad."/>
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Custom letter" FontFamily="Consolas"/>
                                <TextBlock Grid.Row="1" Grid.Column="1" TextWrapping="Wrap"
                                           Text="Set a single letter in the destination editor for a memorable shortcut (e.g. K for Keep, A for Archive)."/>
                            </Grid>

                            <TextBlock Text="Move vs. Copy" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="The toolbar Action selector controls what happens when a hotkey or destination button fires. Move removes the file from the source folder; Copy leaves the original in place. The setting applies equally to button clicks and hotkey presses."/>

                            <TextBlock Text="Multi-select" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Hold Shift or Ctrl to select multiple items, then press a destination hotkey or click its button — every selected file is sent in one batch. The source-to-destination animation now plays for each item, fanning out to make the action visible."/>

                            <TextBlock Text="Kind filter" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="A destination can be restricted to Image-only or Video-only. If you send a mixed selection, only matching files go through and the status bar reports how many were skipped."/>

                            <TextBlock Text="Conflicts" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="If a file with the same name already exists in the destination, MediaSort follows the conflict policy from Settings (Prompt, Skip, Overwrite, or Rename). When prompted you can apply your choice to the rest of the batch."/>

                            <TextBlock Text="Undo" FontWeight="Bold" FontSize="14" Margin="0,8,0,6"/>
                            <TextBlock TextWrapping="Wrap" Margin="0,0,0,10"
                                Text="Ctrl+Z reverses the last action — including a multi-file batch. Items are returned to their original folder and selection is restored."/>

                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </DockPanel>
</Window>
