<Window x:Class="MediaSort.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:conv="clr-namespace:MediaSort.Converters"
        xmlns:models="clr-namespace:MediaSort.Models"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        Title="MediaSort"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="820" Width="1480"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterScreen"
        Opacity="0"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">
    <Window.Resources>
        <conv:MediaKindToVisibilityConverter x:Key="KindVis"/>
        <conv:ViewModeToVisibilityConverter x:Key="ModeVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <!-- Thumbnail tile dimensions — updated at runtime from settings -->
        <sys:Double x:Key="ThumbTileSize">120</sys:Double>
        <sys:Double x:Key="ThumbTileHeight">140</sys:Double>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- Top Toolbar (row 1) -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelHeader}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="6,4,6,2">
                    <Button Content="Pick Source Folder..." Style="{StaticResource ToolButton}" Click="PickSource_Click"
                            ToolTip="Choose the folder MediaSort will scan for media"/>
                    <Button x:Name="RecentSourceButton" Content="Recent ▾" Style="{StaticResource ToolButton}"
                            Margin="4,0,0,0" Click="RecentSource_Click"
                            ToolTip="Switch to a recently-used source folder"/>
                    <TextBlock x:Name="SourcePathText" Text="(no source folder)"
                               VerticalAlignment="Center" Margin="10,0"
                               Foreground="{DynamicResource MutedForeground}"
                               MaxWidth="500" TextTrimming="CharacterEllipsis"/>
                    <!-- (#16) Banner shown when the source folder becomes unreachable. -->
                    <Border x:Name="SourceOfflineBanner" Visibility="Collapsed"
                            Background="#E07A28" Padding="8,2" CornerRadius="4"
                            VerticalAlignment="Center" Margin="6,0,0,0"
                            ToolTip="The source folder is currently unreachable. Reconnect the drive or network share to continue.">
                        <TextBlock Text="⚠ Source offline" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    </Border>

                    <Separator Margin="6,0"/>

                    <TextBlock Text="View:" VerticalAlignment="Center" Margin="6,0,4,0"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox x:Name="ViewModeCombo" Width="110"
                              SelectionChanged="ViewModeCombo_SelectionChanged"
                              VerticalAlignment="Center"
                              ToolTip="Switch source list between List, Details, and Thumbnails view">
                        <ComboBoxItem Content="List"/>
                        <ComboBoxItem Content="Details" IsSelected="True"/>
                        <ComboBoxItem Content="Thumbnails"/>
                    </ComboBox>

                    <TextBlock Text="Sort:" VerticalAlignment="Center" Margin="12,0,4,0"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox x:Name="SortKeyCombo" Width="110"
                              SelectionChanged="SortKeyCombo_SelectionChanged"
                              VerticalAlignment="Center"
                              ToolTip="Sort the source list by this property">
                        <ComboBoxItem Content="Name" IsSelected="True"/>
                        <ComboBoxItem Content="Size"/>
                        <ComboBoxItem Content="Aspect"/>
                        <ComboBoxItem Content="Modified"/>
                        <ComboBoxItem Content="Kind"/>
                        <ComboBoxItem Content="Duration"/>
                    </ComboBox>
                    <Button x:Name="SortDirButton" Content="▲" Width="30"
                            Style="{StaticResource ToolButton}"
                            Margin="4,0,0,0" Click="SortDir_Click"
                            ToolTip="Toggle sort direction"/>

                    <CheckBox x:Name="RecursiveCheck" Content="Recursive"
                              Foreground="{DynamicResource PanelForeground}"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              Checked="Recursive_Changed" Unchecked="Recursive_Changed"
                              ToolTip="Include subfolders when scanning the source folder"/>

                    <Button Content="Refresh" Style="{StaticResource ToolButton}" Margin="12,0,0,0" Click="Refresh_Click"
                            ToolTip="Re-scan the source folder for new or changed files (F5)"/>
                    <Button Content="Regen Thumbnails" Style="{StaticResource ToolButton}" Margin="6,0,0,0"
                            Click="RegenThumbnails_Click"
                            ToolTip="Force-regenerate thumbnails for all items in the source list"/>
                    <Separator Margin="6,0"/>

                    <Button Content="Settings" Style="{StaticResource ToolButton}" Click="Settings_Click"
                            ToolTip="Open the Settings dialog (Ctrl+,)"/>
                    <Button Content="?" Style="{StaticResource ToolButton}" Width="28" ToolTip="Keyboard shortcuts"
                            Click="Help_Click" Margin="6,0,0,0"/>
                    <Button Content="About" Style="{StaticResource ToolButton}" Click="About_Click"
                            ToolTip="Show app version and credits"/>
                </StackPanel>

                <!-- Toolbar row 2: filters + search -->
                <StackPanel Orientation="Horizontal" Margin="6,2,6,4">
                    <TextBlock Text="Search:" VerticalAlignment="Center" Margin="0,0,4,0"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <TextBox x:Name="SearchBox" Width="220" VerticalAlignment="Center"
                             TextChanged="SearchBox_TextChanged"
                             ToolTip="Filter the source list (Ctrl+F)"/>
                    <Button Content="✕" Width="24" Margin="2,0,0,0" Style="{StaticResource ToolButton}"
                            Click="ClearSearch_Click" ToolTip="Clear"/>

                    <TextBlock Text="Date:" VerticalAlignment="Center" Margin="14,0,4,0"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox x:Name="DateFilterCombo" Width="120" VerticalAlignment="Center"
                              SelectionChanged="DateFilterCombo_SelectionChanged"
                              ToolTip="Limit the source list to files modified within this time range">
                        <ComboBoxItem Content="All time" IsSelected="True"/>
                        <ComboBoxItem Content="Last 7 days"/>
                        <ComboBoxItem Content="Last 30 days"/>
                        <ComboBoxItem Content="This year"/>
                    </ComboBox>

                    <TextBlock Text="Aspect:" VerticalAlignment="Center" Margin="14,0,4,0"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox x:Name="AspectFilterCombo" Width="110" VerticalAlignment="Center"
                              SelectionChanged="AspectFilterCombo_SelectionChanged"
                              ToolTip="Filter by image/video orientation (Portrait, Landscape, Square)">
                        <ComboBoxItem Content="Any" IsSelected="True"/>
                        <ComboBoxItem Content="Portrait"/>
                        <ComboBoxItem Content="Landscape"/>
                        <ComboBoxItem Content="Square"/>
                    </ComboBox>

                    <TextBlock Text="Action:" VerticalAlignment="Center" Margin="14,0,4,0"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox x:Name="ActionCombo" Width="100" VerticalAlignment="Center"
                              SelectionChanged="ActionCombo_SelectionChanged"
                              ToolTip="What to do when a destination is activated: Move (default), Copy (keep original), or Delete (send original to Recycle Bin and ignore destination folder)">
                        <ComboBoxItem Content="Move" IsSelected="True"/>
                        <ComboBoxItem Content="Copy"/>
                        <ComboBoxItem Content="Delete"/>
                    </ComboBox>

                    <Button Content="Find duplicates" Style="{StaticResource ToolButton}" Margin="14,0,0,0"
                            Click="FindDuplicates_Click" ToolTip="Highlight near-duplicate images"/>
                    <Button x:Name="SelectAllButton" Content="Select All" Style="{StaticResource ToolButton}" Margin="6,0,0,0"
                            Click="SelectAll_Click" ToolTip="Select every visible item in the source list (Ctrl+A)"/>
                    <Button x:Name="UndoButton" Content="↶ Undo" Style="{StaticResource ToolButton}" Margin="6,0,0,0"
                            Click="Undo_Click" ToolTip="Undo last move or batch (Ctrl+Z)" IsEnabled="False"/>
                    <Button Content="Skip (N)" Style="{StaticResource ToolButton}" Margin="6,0,0,0"
                            Click="Skip_Click" ToolTip="Advance to next without moving"/>
                    <Button Content="🗑 Trash" Style="{StaticResource ToolButton}" Margin="6,0,0,0"
                            Click="Trash_Click" ToolTip="Send selected to Recycle Bin (Del)"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelHeader}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="0,1,0,0">
            <Grid Margin="6,3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready" Foreground="{DynamicResource MutedForeground}"/>
                <TextBlock Grid.Column="1" x:Name="StatsText" Text="" Foreground="{DynamicResource MutedForeground}"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="380" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="340" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Source list -->
            <Border Grid.Column="0"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource PanelHeader}" Padding="8,4">
                        <TextBlock Text="Source" FontWeight="Bold" Foreground="{DynamicResource PanelForeground}"/>
                    </Border>

                    <Grid DockPanel.Dock="Bottom" Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pos" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <Slider Grid.Column="1" x:Name="PositionSlider" Minimum="0" Maximum="0"
                                SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" TickFrequency="1"
                                ValueChanged="PositionSlider_ValueChanged"
                                ToolTip="Jump to a specific position in the source list"/>
                        <TextBlock Grid.Column="2" x:Name="PositionText" Text="0/0" VerticalAlignment="Center" Margin="6,0,0,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                    </Grid>

                    <Grid>
                        <ListBox x:Name="ListView_List"
                                 Visibility="Collapsed"
                                 Background="{DynamicResource PanelBackground}"
                                 Foreground="{DynamicResource PanelForeground}"
                                 BorderThickness="0"
                                 SelectionMode="Extended"
                                 SelectionChanged="MediaList_SelectionChanged"
                                 KeyDown="MediaList_KeyDown">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <MenuItem Header="Copy full path" Click="CopyPath_Click"/>
                                    <MenuItem Header="Rename..." InputGestureText="F2" Click="Rename_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Send to Recycle Bin" Click="Trash_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox VerticalAlignment="Center" Margin="0,0,6,0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  ToolTip="Select this item"/>
                                        <TextBlock Text="{Binding StarGlyph}" Foreground="#F5C518"
                                                   FontWeight="Bold" VerticalAlignment="Center"
                                                   Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListView x:Name="ListView_Details"
                                  Background="{DynamicResource PanelBackground}"
                                  Foreground="{DynamicResource PanelForeground}"
                                  BorderThickness="0"
                                  SelectionMode="Extended"
                                  SelectionChanged="MediaList_SelectionChanged"
                                  KeyDown="MediaList_KeyDown">
                            <ListView.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <MenuItem Header="Copy full path" Click="CopyPath_Click"/>
                                    <MenuItem Header="Rename..." InputGestureText="F2" Click="Rename_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Send to Recycle Bin" Click="Trash_Click"/>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="32">
                                        <GridViewColumnHeader Content=""/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          ToolTip="Select this item"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="24">
                                        <GridViewColumnHeader Content="★" ToolTip="Favorite"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StarGlyph}" Foreground="#F5C518"
                                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="180" DisplayMemberBinding="{Binding FileName}">
                                        <GridViewColumnHeader Content="Name" Tag="Name" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="80" DisplayMemberBinding="{Binding SizeDisplay}">
                                        <GridViewColumnHeader Content="Size" Tag="Size" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding AspectDisplay}">
                                        <GridViewColumnHeader Content="Aspect" Tag="Aspect" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="70" DisplayMemberBinding="{Binding DurationDisplay}">
                                        <GridViewColumnHeader Content="Duration" Tag="Duration" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding ModifiedDate, StringFormat=yyyy-MM-dd HH:mm}">
                                        <GridViewColumnHeader Content="Modified" Tag="Modified" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ListBox x:Name="ListView_Thumbs"
                                 Background="{DynamicResource PanelBackground}"
                                 Foreground="{DynamicResource PanelForeground}"
                                 BorderThickness="0"
                                 SelectionMode="Extended"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="MediaList_SelectionChanged"
                                 KeyDown="MediaList_KeyDown">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
                                    <MenuItem Header="Copy full path" Click="CopyPath_Click"/>
                                    <MenuItem Header="Rename..." InputGestureText="F2" Click="Rename_Click"/>
                                    <Separator/>
                                    <MenuItem Header="Send to Recycle Bin" Click="Trash_Click"/>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel HorizontalAlignment="Center"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{DynamicResource ThumbTileSize}" Height="{DynamicResource ThumbTileHeight}" Margin="4"
                                            Background="{DynamicResource ItemBackground}"
                                            BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1"
                                            ToolTip="{Binding FullPath}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Bottom" Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                       Foreground="{DynamicResource PanelForeground}" Margin="2"/>
                                            <Grid Background="{DynamicResource PreviewBackground}" Margin="2">
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"/>
                                                <TextBlock Text="🎬" FontSize="32"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Kind, Converter={StaticResource KindVis}, ConverterParameter=Video}"/>
                                                <TextBlock Text="🖼" FontSize="32" Opacity="0.35"
                                                           Foreground="{DynamicResource MutedForeground}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Thumbnail, Converter={StaticResource NullVis}, ConverterParameter=Invert}"/>
                                                <Border Background="#CCFF6B6B" CornerRadius="3" Padding="4,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"
                                                        Visibility="{Binding IsDuplicate, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="DUP" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4"
                                                          Background="#CC000000"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          ToolTip="Select this item"/>
                                                <TextBlock Text="{Binding StarGlyph}" Foreground="#F5C518"
                                                           FontWeight="Bold" FontSize="18"
                                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                           Margin="4"
                                                           Effect="{x:Null}"/>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBrush}"
                          DragCompleted="PanelSplitter_DragCompleted"/>

            <!-- CENTER: Preview -->
            <Border Grid.Column="2" Background="{DynamicResource PreviewBackground}">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource PanelHeader}" Padding="8,4">
                        <TextBlock x:Name="PreviewTitle" Text="Preview" FontWeight="Bold"
                                   Foreground="{DynamicResource PanelForeground}"/>
                    </Border>

                    <Border DockPanel.Dock="Bottom" x:Name="VideoControls"
                            Background="{DynamicResource PanelBackground}" Padding="8,6"
                            Visibility="Collapsed">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Button Content="▶/⏸" Width="46" Style="{StaticResource ToolButton}" Click="VideoTogglePlay_Click" ToolTip="Play / Pause (Space)"/>
                                <Button Content="⏹" Width="32" Style="{StaticResource ToolButton}" Click="VideoStop_Click"
                                        ToolTip="Stop playback"/>
                                <ToggleButton x:Name="LoopToggle" Content="↻" Width="32" Margin="4,0,0,0"
                                              ToolTip="Loop"/>
                                <!-- (#20) Audio preview: mute toggle + volume slider. M toggles mute. -->
                                <ToggleButton x:Name="MuteToggle" Content="🔊" Width="32" Margin="8,0,0,0"
                                              ToolTip="Mute / unmute (M)" Click="MuteToggle_Click"/>
                                <Slider x:Name="VolumeSlider" Width="90" Minimum="0" Maximum="100"
                                        Margin="6,0,0,0" VerticalAlignment="Center"
                                        ToolTip="Volume (0–100)"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right" x:Name="VideoTimeText" Text="0:00 / 0:00"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Foreground="{DynamicResource MutedForeground}"/>
                            <Slider x:Name="VideoScrub" Minimum="0" Maximum="1000" Margin="10,0"
                                    VerticalAlignment="Center"
                                    Thumb.DragStarted="VideoScrub_DragStarted"
                                    Thumb.DragCompleted="VideoScrub_DragCompleted"
                                    PreviewMouseDown="VideoScrub_PreviewMouseDown"/>
                        </DockPanel>
                    </Border>

                    <Grid x:Name="PreviewArea" ClipToBounds="True">
                        <ScrollViewer x:Name="PreviewScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10" Visibility="Collapsed"
                                   MaxWidth="{Binding ViewportWidth, ElementName=PreviewScroll}"
                                   MaxHeight="{Binding ViewportHeight, ElementName=PreviewScroll}"
                                   MouseWheel="PreviewImage_MouseWheel"
                                   MouseLeftButtonDown="PreviewImage_MouseDown"
                                   MouseLeftButtonUp="PreviewImage_MouseUp"
                                   MouseMove="PreviewImage_MouseMove">
                                <Image.LayoutTransform>
                                    <ScaleTransform x:Name="PreviewImageScale" ScaleX="1" ScaleY="1"/>
                                </Image.LayoutTransform>
                            </Image>
                        </ScrollViewer>
                        <vlc:VideoView x:Name="PreviewVideo" Margin="10" Visibility="Collapsed"/>
                        <TextBlock x:Name="PreviewEmpty" Text="Select a media file to preview"
                                   Foreground="{DynamicResource EmptyForeground}" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch"
                          Background="{DynamicResource SplitterBrush}"
                          DragCompleted="PanelSplitter_DragCompleted"/>

            <!-- RIGHT: Destinations + EXIF -->
            <Border Grid.Column="4"
                    Background="{DynamicResource PanelBackground}"
                    BorderBrush="{DynamicResource BorderBrushColor}"
                    BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="{DynamicResource PanelHeader}" Padding="8,4">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="+ Add" Style="{StaticResource ToolButton}" Click="AddDestination_Click"
                                    ToolTip="Add a new destination button (folder + hotkey)"/>
                            <TextBlock Text="Destinations" FontWeight="Bold"
                                       Foreground="{DynamicResource PanelForeground}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- EXIF / file info section pinned to bottom -->
                    <Expander DockPanel.Dock="Bottom" Header="File info / EXIF" IsExpanded="False"
                              Foreground="{DynamicResource PanelForeground}" Margin="6,4">
                        <ItemsControl x:Name="ExifItems" Margin="6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource MutedForeground}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- (#5) Virtualized destinations: ItemsControl with its own ScrollViewer
                         and a VirtualizingStackPanel so 100s of dests scroll smoothly. -->
                    <ItemsControl x:Name="DestinationsPanel"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer Focusable="False"
                                                      CanContentScroll="True"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel IsItemsHost="True" Orientation="Vertical"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,4" Tag="{Binding}">
                                        <Border Background="{DynamicResource ItemBackground}"
                                                BorderBrush="{DynamicResource BorderBrushColor}"
                                                BorderThickness="1" Padding="6"
                                                Tag="{Binding}">
                                            <DockPanel>
                                                <!-- (#10) Click-and-hold drag handle. Press, hold, drag up/down to reorder. -->
                                                <Border DockPanel.Dock="Left" Width="14" Margin="0,0,4,0"
                                                        Background="Transparent" Cursor="SizeAll"
                                                        ToolTip="Click and hold, then drag up or down to reorder"
                                                        Tag="{Binding}"
                                                        PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown">
                                                    <TextBlock Text="⋮⋮" FontSize="14" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource MutedForeground}"
                                                               IsHitTestVisible="False"/>
                                                </Border>
                                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                    <Button Content="↑" Width="22" Margin="1,0" Click="MoveDestUp_Click" Tag="{Binding}" ToolTip="Move up"/>
                                                    <Button Content="↓" Width="22" Margin="1,0" Click="MoveDestDown_Click" Tag="{Binding}" ToolTip="Move down"/>
                                                    <Button Content="📂" Width="28" Margin="2,0" Click="OpenDestFolder_Click" Tag="{Binding}" ToolTip="Open folder in Explorer"/>
                                                    <Button Content="➜" Width="28" Margin="2,0" Click="UseDestAsSource_Click" Tag="{Binding}" ToolTip="Open this destination as the source folder"/>
                                                    <Button Content="✎" Width="28" Margin="2,0" Click="EditDestination_Click" Tag="{Binding}" ToolTip="Edit"/>
                                                    <Button Content="✕" Width="28" Margin="2,0" Click="RemoveDestination_Click" Tag="{Binding}" ToolTip="Remove"/>
                                                </StackPanel>
                                                <Button Style="{StaticResource DestButton}" Click="SendToDestination_Click" Tag="{Binding}"
                                                        Opacity="{Binding BadgeOpacity}"
                                                        ToolTip="Click: send selected items here&#x0A;Ctrl+Click: open this folder in Explorer">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                        <TextBlock Text="{Binding HotKeyDisplay}" FontSize="10" Opacity="0.8"/>
                                                        <TextBlock Text="{Binding FolderPath}" FontSize="10" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Text="{Binding BadgeText}" FontSize="10" Opacity="0.65" FontStyle="Italic"/>
                                                        <TextBlock Text="{Binding StatusGlyph}" ToolTip="{Binding StatusGlyphTooltip}"
                                                                   FontSize="10" FontWeight="Bold" Foreground="#E07A28"/>
                                                    </StackPanel>
                                                </Button>
                                            </DockPanel>
                                        </Border>
                                        <!-- Transient "+N" flash badge after a successful move (top-right). -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,-6,-6,0" Padding="7,2"
                                                CornerRadius="10"
                                                Background="#1FA463"
                                                BorderBrush="White" BorderThickness="1"
                                                IsHitTestVisible="False"
                                                Opacity="{Binding FlashOpacity}">
                                            <TextBlock Text="{Binding FlashBadge}"
                                                       Foreground="White" FontWeight="Bold" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

    <!-- Overlay layer for fly-to-destination animations -->
    <Canvas x:Name="AnimationOverlay" IsHitTestVisible="False" Background="Transparent"/>
    </Grid>
</Window>
