<Window x:Class="MediaSort.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:MediaSort.Converters"
        xmlns:models="clr-namespace:MediaSort.Models"
        Title="MediaSort"
        Height="800" Width="1400"
        Background="#181818"
        Foreground="#EEE"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Window.Resources>
        <conv:MediaKindToVisibilityConverter x:Key="KindVis"/>
        <conv:ViewModeToVisibilityConverter x:Key="ModeVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
    </Window.Resources>

    <DockPanel>
        <!-- Top Toolbar -->
        <Border DockPanel.Dock="Top" Background="#222" BorderBrush="#333" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Margin="6">
                <Button Content="Pick Source Folder..." Style="{StaticResource ToolButton}" Click="PickSource_Click"/>
                <TextBlock x:Name="SourcePathText" Text="(no source folder)" VerticalAlignment="Center" Margin="10,0" Foreground="#AAA" MaxWidth="600" TextTrimming="CharacterEllipsis"/>

                <Separator Margin="6,0"/>

                <TextBlock Text="View:" VerticalAlignment="Center" Margin="6,0,4,0"/>
                <ComboBox x:Name="ViewModeCombo" Width="110" SelectionChanged="ViewModeCombo_SelectionChanged" VerticalAlignment="Center">
                    <ComboBoxItem Content="List"/>
                    <ComboBoxItem Content="Details" IsSelected="True"/>
                    <ComboBoxItem Content="Thumbnails"/>
                </ComboBox>

                <CheckBox x:Name="RecursiveCheck" Content="Recursive" Foreground="#DDD" VerticalAlignment="Center" Margin="12,0,0,0" Checked="Recursive_Changed" Unchecked="Recursive_Changed"/>

                <Button Content="Refresh" Style="{StaticResource ToolButton}" Margin="12,0,0,0" Click="Refresh_Click"/>

                <Separator Margin="6,0"/>

                <Button Content="Settings" Style="{StaticResource ToolButton}" Click="Settings_Click"/>
                <Button Content="About" Style="{StaticResource ToolButton}" Click="About_Click"/>
            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="#222" BorderBrush="#333" BorderThickness="0,1,0,0">
            <StackPanel Orientation="Horizontal" Margin="6,3">
                <TextBlock x:Name="StatusText" Text="Ready" Foreground="#AAA"/>
            </StackPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="380" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="220"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Source list -->
            <Border Grid.Column="0" Background="#1E1E1E" BorderBrush="#333" BorderThickness="0,0,1,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4">
                        <TextBlock Text="Source" FontWeight="Bold" Foreground="#DDD"/>
                    </Border>

                    <!-- Slider on bottom of list -->
                    <Grid DockPanel.Dock="Bottom" Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pos" VerticalAlignment="Center" Margin="0,0,6,0" Foreground="#AAA"/>
                        <Slider Grid.Column="1" x:Name="PositionSlider" Minimum="0" Maximum="0" SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" TickFrequency="1" ValueChanged="PositionSlider_ValueChanged"/>
                        <TextBlock Grid.Column="2" x:Name="PositionText" Text="0/0" VerticalAlignment="Center" Margin="6,0,0,0" Foreground="#AAA"/>
                    </Grid>

                    <Grid>
                        <!-- List View -->
                        <ListBox x:Name="ListView_List"
                                 Visibility="Collapsed"
                                 Background="#1E1E1E" Foreground="#DDD" BorderThickness="0"
                                 SelectionChanged="MediaList_SelectionChanged"
                                 KeyDown="MediaList_KeyDown">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FileName}"/>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- Details View -->
                        <ListView x:Name="ListView_Details"
                                  Background="#1E1E1E" Foreground="#DDD" BorderThickness="0"
                                  SelectionChanged="MediaList_SelectionChanged"
                                  KeyDown="MediaList_KeyDown">
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Header="Name" Width="180" DisplayMemberBinding="{Binding FileName}"/>
                                    <GridViewColumn Header="Size" Width="80" DisplayMemberBinding="{Binding SizeDisplay}"/>
                                    <GridViewColumn Header="Modified" Width="120" DisplayMemberBinding="{Binding ModifiedDate, StringFormat=yyyy-MM-dd HH:mm}"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Thumbnails View -->
                        <ListBox x:Name="ListView_Thumbs"
                                 Background="#1E1E1E" Foreground="#DDD" BorderThickness="0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 SelectionChanged="MediaList_SelectionChanged"
                                 KeyDown="MediaList_KeyDown">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="120" Height="140" Margin="4" Background="#262626" BorderBrush="#444" BorderThickness="1">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Bottom" Text="{Binding FileName}" TextTrimming="CharacterEllipsis" TextAlignment="Center" Foreground="#DDD" Margin="2"/>
                                            <Grid>
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform" Margin="2"/>
                                                <TextBlock Text="🎬" FontSize="32" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Kind, Converter={StaticResource KindVis}, ConverterParameter=Video}"/>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="#0A0A0A"/>

            <!-- CENTER: Preview -->
            <Border Grid.Column="2" Background="#0F0F0F">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4">
                        <TextBlock x:Name="PreviewTitle" Text="Preview" FontWeight="Bold" Foreground="#DDD"/>
                    </Border>

                    <Border DockPanel.Dock="Bottom" Background="#1A1A1A" Padding="8,6"
                            Visibility="{Binding ElementName=PreviewVideo, Path=Source, Converter={StaticResource NullVis}}">
                        <StackPanel Orientation="Horizontal">
                            <Button Content="▶ Play" Style="{StaticResource ToolButton}" Click="VideoPlay_Click"/>
                            <Button Content="⏸ Pause" Style="{StaticResource ToolButton}" Click="VideoPause_Click"/>
                            <Button Content="⏹ Stop" Style="{StaticResource ToolButton}" Click="VideoStop_Click"/>
                        </StackPanel>
                    </Border>

                    <Grid>
                        <!-- Image preview -->
                        <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10"/>
                        <!-- Video preview -->
                        <MediaElement x:Name="PreviewVideo" LoadedBehavior="Manual" UnloadedBehavior="Stop" Stretch="Uniform" Margin="10"/>
                        <!-- Empty placeholder -->
                        <TextBlock x:Name="PreviewEmpty" Text="Select a media file to preview" Foreground="#666" FontSize="16" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Column="3" Width="5" HorizontalAlignment="Stretch" Background="#0A0A0A"/>

            <!-- RIGHT: Destination buttons -->
            <Border Grid.Column="4" Background="#1E1E1E" BorderBrush="#333" BorderThickness="1,0,0,0">
                <DockPanel>
                    <Border DockPanel.Dock="Top" Background="#252525" Padding="8,4">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Content="+ Add" Style="{StaticResource ToolButton}" Click="AddDestination_Click"/>
                            <TextBlock Text="Destinations" FontWeight="Bold" Foreground="#DDD" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <ItemsControl x:Name="DestinationsPanel">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="#262626" BorderBrush="#3A3A3A" BorderThickness="1" Margin="6,4" Padding="6">
                                        <DockPanel>
                                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                                                <Button Content="✎" Width="28" Margin="2,0" Click="EditDestination_Click" Tag="{Binding}" ToolTip="Edit"/>
                                                <Button Content="✕" Width="28" Margin="2,0" Click="RemoveDestination_Click" Tag="{Binding}" ToolTip="Remove"/>
                                            </StackPanel>
                                            <Button Style="{StaticResource DestButton}" Click="SendToDestination_Click" Tag="{Binding}">
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                                    <TextBlock Text="{Binding HotKeyDisplay}" FontSize="10" Opacity="0.8"/>
                                                    <TextBlock Text="{Binding FolderPath}" FontSize="10" Opacity="0.7" TextTrimming="CharacterEllipsis"/>
                                                </StackPanel>
                                            </Button>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
