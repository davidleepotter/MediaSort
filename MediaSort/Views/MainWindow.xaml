<Window x:Class="MediaSort.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        xmlns:conv="clr-namespace:MediaSort.Converters"
        xmlns:models="clr-namespace:MediaSort.Models"
        xmlns:vlc="clr-namespace:LibVLCSharp.WPF;assembly=LibVLCSharp.WPF"
        xmlns:vwp="clr-namespace:WpfToolkit.Controls;assembly=VirtualizingWrapPanel"
        Title="MediaSort"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="820" Width="1480"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterScreen"
        Opacity="0"
        KeyDown="Window_KeyDown"
        KeyUp="Window_KeyUp">
    <Window.Resources>
        <conv:MediaKindToVisibilityConverter x:Key="KindVis"/>
        <conv:ViewModeToVisibilityConverter x:Key="ModeVis"/>
        <conv:NullToVisibilityConverter x:Key="NullVis"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
        <!-- Thumbnail tile dimensions — updated at runtime from settings -->
        <sys:Double x:Key="ThumbTileSize">120</sys:Double>
        <sys:Double x:Key="ThumbTileHeight">140</sys:Double>
        <!-- Destination button text fonts/sizes — updated at runtime from settings.
             Per-line: folder name, hotkey, folder path, file-count badge. -->
        <FontFamily x:Key="DestNameFontFamily">Segoe UI</FontFamily>
        <sys:Double x:Key="DestNameFontSize">12</sys:Double>
        <FontFamily x:Key="DestKeyFontFamily">Segoe UI</FontFamily>
        <sys:Double x:Key="DestKeyFontSize">10</sys:Double>
        <FontFamily x:Key="DestPathFontFamily">Segoe UI</FontFamily>
        <sys:Double x:Key="DestPathFontSize">10</sys:Double>
        <FontFamily x:Key="DestBadgeFontFamily">Segoe UI</FontFamily>
        <sys:Double x:Key="DestBadgeFontSize">10</sys:Double>

        <!-- Destination button overall size (compact / normal / large).
             Updated at runtime from settings via ApplyDestButtonSize().
             DestTileWidth controls the per-tile width that drives multi-column
             wrap layout in the destinations panel. -->
        <sys:Double x:Key="DestButtonMinHeight">42</sys:Double>
        <Thickness x:Key="DestButtonPadding">8,6</Thickness>
        <sys:Double x:Key="DestTileWidth">220</sys:Double>

        <!-- Shared context menu for all three source-list views (List/Details/Thumbnails).
             The 'Send to' submenu is populated dynamically in MediaList_ContextMenuOpening
             from the current Destinations collection so menu items always match the right
             panel without us hand-syncing on add/edit/remove. -->
        <ContextMenu x:Key="MediaListContextMenu" Opened="MediaListContextMenu_Opened">
            <MenuItem Header="Open in Explorer" Click="OpenInExplorer_Click"/>
            <MenuItem Header="Copy full path" Click="CopyPath_Click"/>
            <MenuItem Header="Rename..." InputGestureText="F2" Click="Rename_Click"/>
            <MenuItem Header="Rotate">
                <MenuItem Header="Rotate 90° Clockwise" Click="RotateClockwise_Click"/>
                <MenuItem Header="Rotate 90° Counter-Clockwise" Click="RotateCounterClockwise_Click"/>
                <MenuItem Header="Rotate 180°" Click="Rotate180_Click"/>
            </MenuItem>
            <Separator Tag="SendToSep"/>
            <!-- 'Send to' children populated in code-behind on Opened.
                 Tag=SendTo so the handler can locate the submenu without x:Name
                 (which doesn't reliably resolve for shared resource items). -->
            <MenuItem Header="Send to" Tag="SendTo"/>
            <Separator Tag="SendToSepBottom"/>
            <MenuItem Header="Send to Recycle Bin" Click="Trash_Click"/>
        </ContextMenu>
    </Window.Resources>

    <Grid>
    <DockPanel>
        <!-- Top Toolbar (row 1) -->
        <Border DockPanel.Dock="Top"
                Background="{DynamicResource PanelHeader}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="0,0,0,1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="6,4,6,2">
                    <Button Content="Pick Source Folder..." Style="{StaticResource SourceToolButton}" Click="PickSource_Click"
                            ToolTip="Choose the folder MediaSort will scan for media"/>
                    <Button x:Name="RecentSourceButton" Content="Recent ▾" Style="{StaticResource SourceToolButton}"
                            Margin="4,0,0,0" Click="RecentSource_Click"
                            ToolTip="Switch to a recently-used source folder"/>
                    <TextBlock x:Name="SourcePathText" Text="(no source folder)"
                               VerticalAlignment="Center" Margin="10,0"
                               Foreground="{DynamicResource MutedForeground}"
                               MaxWidth="500" TextTrimming="CharacterEllipsis"/>
                    <!-- (#16) Banner shown when the source folder becomes unreachable. -->
                    <Border x:Name="SourceOfflineBanner" Visibility="Collapsed"
                            Background="#E07A28" Padding="8,2" CornerRadius="4"
                            VerticalAlignment="Center" Margin="6,0,0,0"
                            ToolTip="The source folder is currently unreachable. Reconnect the drive or network share to continue.">
                        <TextBlock Text="⚠ Source offline" Foreground="White" FontWeight="Bold" FontSize="11"/>
                    </Border>

                    <Separator Margin="6,0"/>
                    <!-- (View, thumb-size, Sort key, and direction moved to Source pane header) -->

                    <!-- (Recursive checkbox moved to Source pane action row) -->

                    <Button Content="Refresh" Style="{StaticResource UtilityToolButton}" Margin="12,0,0,0" Click="Refresh_Click"
                            ToolTip="Re-scan the source folder for new or changed files (F5)"/>
                    <Button Content="Regen Thumbnails" Style="{StaticResource UtilityToolButton}" Margin="6,0,0,0"
                            Click="RegenThumbnails_Click"
                            ToolTip="Force-regenerate thumbnails for all items in the source list"/>
                    <Separator Margin="6,0"/>

                    <Button Content="Settings" Style="{StaticResource InfoToolButton}" Click="Settings_Click"
                            ToolTip="Open the Settings dialog (Ctrl+,)"/>
                    <!-- Panes▾ — toggle visibility / restore-default-layout for the three main panes. -->
                    <Button x:Name="PanesMenuButton" Content="Panes ▾" Style="{StaticResource PaneToolButton}"
                            Margin="6,0,0,0" Click="PanesMenu_Click"
                            ToolTip="Show/hide Source, Preview, or Destinations panes; reset layout">
                        <Button.ContextMenu>
                            <ContextMenu x:Name="PanesContextMenu">
                                <MenuItem x:Name="ToggleSourceMenuItem" Header="Source" IsCheckable="True"
                                          Click="TogglePaneVisibility_Click" Tag="Source"/>
                                <MenuItem x:Name="TogglePreviewMenuItem" Header="Preview" IsCheckable="True"
                                          Click="TogglePaneVisibility_Click" Tag="Preview"/>
                                <MenuItem x:Name="ToggleDestinationsMenuItem" Header="Destinations" IsCheckable="True"
                                          Click="TogglePaneVisibility_Click" Tag="Destinations"/>
                                <Separator/>
                                <MenuItem Header="Reset to default layout" Click="ResetPaneLayout_Click"
                                          ToolTip="Restore order Source / Preview / Destinations and show all panes"/>
                            </ContextMenu>
                        </Button.ContextMenu>
                    </Button>
                    <Button Content="History…" Style="{StaticResource PrimaryToolButton}" Margin="6,0,0,0"
                            Click="History_Click" ToolTip="Browse all undo batches and undo any one of them (Ctrl+H)"/>
                    <Button Content="?" Style="{StaticResource InfoToolButton}" Width="28" ToolTip="Keyboard shortcuts"
                            Click="Help_Click" Margin="6,0,0,0"/>
                    <Button Content="About" Style="{StaticResource InfoToolButton}" Click="About_Click"
                            ToolTip="Show app version and credits"/>
                </StackPanel>

            </StackPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom"
                Background="{DynamicResource PanelHeader}"
                BorderBrush="{DynamicResource BorderBrushColor}"
                BorderThickness="0,1,0,0">
            <Grid Margin="8,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedForeground}"/>
                <!-- (UX R3) Subtle vertical separator between status and session totals. -->
                <Rectangle Grid.Column="1" Width="1" Margin="10,2"
                           Fill="{DynamicResource BorderBrushColor}" Opacity="0.6"/>
                <!-- (#11) Session statistics. Click for breakdown / reset. -->
                <TextBlock Grid.Column="2" x:Name="SessionStatsText" Text="Session: 0 files"
                           VerticalAlignment="Center"
                           Foreground="{DynamicResource MutedForeground}"
                           Cursor="Hand"
                           ToolTip="Session totals (moved · copied · deleted · bytes). Click for breakdown."
                           MouseLeftButtonUp="SessionStatsText_MouseLeftButtonUp"/>
                <Rectangle Grid.Column="3" Width="1" Margin="10,2"
                           Fill="{DynamicResource BorderBrushColor}" Opacity="0.6"/>
                <!-- (UX R5) Live-metrics chip: shown items · total bytes · selected count · selected bytes.
                     Wrapped in a rounded Border so it reads as a discrete pill, not loose status text —
                     mirrors the visual weight of the destination action chips. -->
                <Border Grid.Column="4"
                        Background="{DynamicResource ItemBackground}"
                        BorderBrush="{DynamicResource BorderBrushColor}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="8,1"
                        VerticalAlignment="Center">
                    <TextBlock x:Name="StatsText" Text=""
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               FontSize="11"/>
                </Border>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="LeftPanelColumn" Width="380" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="300"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition x:Name="RightPanelColumn" Width="340" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <!-- LEFT: Source list -->
            <Border x:Name="SourcePane" Grid.Column="0"
                    Style="{StaticResource PaneFrameBorder}"
                    Background="{DynamicResource PanelBackground}"
                    GotKeyboardFocus="Pane_GotKeyboardFocus"
                    PreviewMouseDown="Pane_PreviewMouseDown">
                <DockPanel>
                    <Border x:Name="SourcePaneHeader" DockPanel.Dock="Top" Background="{DynamicResource PanelHeader}" Padding="8,4"
                            BorderBrush="{DynamicResource SourceAccentStripe}" BorderThickness="0,3,0,0">
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Left" Text="Source" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PanelForeground}"/>
                            <!-- Right-justified pane controls + jump-to-top / jump-to-bottom. -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="Top" Style="{StaticResource NavToolButton}"
                                        Click="SourceTop_Click"
                                        MinWidth="54" Padding="10,2" Margin="0,0,4,0"
                                        ToolTip="Jump to the first item in the source list (Home)"/>
                                <Button Content="Bottom" Style="{StaticResource NavToolButton}"
                                        Click="SourceBottom_Click"
                                        MinWidth="66" Padding="10,2"
                                        ToolTip="Jump to the last item in the source list (End)"/>
                                <!-- Pane swap/hide toolbar (UX: dockable panes). -->
                                <Separator Margin="6,0,4,0"/>
                                <Button Content="◀" Style="{StaticResource PaneToolButton}"
                                        Tag="Source" Click="PaneMoveLeft_Click"
                                        MinWidth="24" Padding="6,2" Margin="0,0,2,0"
                                        ToolTip="Move this pane one slot to the left"/>
                                <Button Content="▶" Style="{StaticResource PaneToolButton}"
                                        Tag="Source" Click="PaneMoveRight_Click"
                                        MinWidth="24" Padding="6,2" Margin="0,0,2,0"
                                        ToolTip="Move this pane one slot to the right"/>
                                <Button Content="✕" Style="{StaticResource PaneToolButton}"
                                        Tag="Source" Click="PaneHide_Click"
                                        MinWidth="24" Padding="6,2"
                                        ToolTip="Hide this pane (use Panes▾ in toolbar to restore)"/>
                            </StackPanel>
                            <!-- Current source folder name (e.g. 'Master'). Hidden when no folder picked. -->
                            <TextBlock x:Name="SourceFolderNameText"
                                       Margin="8,0,8,0"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource PanelForeground}"
                                       Opacity="0.85"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding ElementName=SourcePathText, Path=Text}"
                                       Text=""/>
                        </DockPanel>
                    </Border>

                    <!-- Source pane control rows. Two horizontal toolbars, each a WrapPanel
                         so controls reflow on narrow widths instead of clipping. Layout rules:
                         • No per-element Margin overrides on Buttons — the Button style
                           already provides Margin="2" so spacing is uniform.
                         • Labels use Margin="8,0,4,0" so they hug the control they label.
                         • ComboBoxes use MinHeight="28" to match button visual height.
                         • ItemHeight on WrapPanel gives consistent row rhythm when wrapping.
                         • Vertical Separator between logical groups instead of variable margins. -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrushColor}"
                            BorderThickness="0,0,0,1"
                            Padding="6,4">
                        <WrapPanel Orientation="Horizontal" ItemHeight="34" VerticalAlignment="Center">
                            <!-- Per-item actions -->
                            <Button Content="Skip (N)" Style="{StaticResource ActionToolButton}"
                                    Click="Skip_Click" ToolTip="Advance to next without moving"/>
                            <Button Content="✎ Rename" Style="{StaticResource ActionToolButton}"
                                    Click="Rename_Click" ToolTip="Rename selected file (F2). Multi-select opens batch rename."/>
                            <Button Content="🗑 Trash" Style="{StaticResource DangerToolButton}"
                                    Click="Trash_Click" ToolTip="Send selected to Recycle Bin (Del)"/>
                            <Button Content="Tags…" Style="{StaticResource ActionToolButton}"
                                    Click="Tags_Click"
                                    ToolTip="Edit ratings and tags for the selected items (Ctrl+T)"/>

                            <Separator Style="{StaticResource VToolbarSeparator}"/>

                            <!-- List-level actions -->
                            <Button Content="Find duplicates" Style="{StaticResource PrimaryToolButton}"
                                    Click="FindDuplicates_Click" ToolTip="Highlight near-duplicate images"/>
                            <Button x:Name="SelectAllButton" Content="Select All" Style="{StaticResource ActionToolButton}"
                                    Click="SelectAll_Click" ToolTip="Select every visible item in the source list (Ctrl+A)"/>
                            <Button x:Name="UndoButton" Content="↶ Undo" Style="{StaticResource PrimaryToolButton}"
                                    Click="Undo_Click" ToolTip="Undo last move or batch (Ctrl+Z)" IsEnabled="False"/>

                            <Separator Style="{StaticResource VToolbarSeparator}"/>

                            <!-- Mode toggles. Each label+control pair is wrapped in a StackPanel
                                 so the outer WrapPanel can NEVER split a label from its control. -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Action:" Style="{StaticResource SourceFieldLabel}"/>
                                <ComboBox x:Name="ActionCombo" Width="100"
                                          Style="{StaticResource SourceFieldCombo}"
                                          SelectionChanged="ActionCombo_SelectionChanged"
                                          ToolTip="What to do when a destination is activated: Move (default), Copy (keep original), or Delete (send original to Recycle Bin and ignore destination folder)">
                                    <ComboBoxItem Content="Move" IsSelected="True"/>
                                    <ComboBoxItem Content="Copy"/>
                                    <ComboBoxItem Content="Delete"/>
                                </ComboBox>
                            </StackPanel>
                            <CheckBox x:Name="RecursiveCheck" Content="Recursive"
                                      Style="{StaticResource SourceFieldCheck}"
                                      Checked="Recursive_Changed" Unchecked="Recursive_Changed"
                                      ToolTip="Include subfolders when scanning the source folder"/>
                        </WrapPanel>
                    </Border>

                    <!-- Sort + filters row: scoped to the Source list. Same layout rules as
                         the action row above for visual consistency. -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrushColor}"
                            BorderThickness="0,0,0,1"
                            Padding="6,4">
                        <WrapPanel Orientation="Horizontal" ItemHeight="34" VerticalAlignment="Center">
                            <!-- Each label+control pair is wrapped in a StackPanel so the outer
                                 WrapPanel can NEVER split a label (e.g. "Action:", "Date:", "Search:")
                                 from the control it labels. WrapPanel only breaks between its
                                 direct children, so each pair is one indivisible unit. -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="View:" Style="{StaticResource SourceFieldLabel}"/>
                                <ComboBox x:Name="ViewModeCombo" Width="110"
                                          Style="{StaticResource SourceFieldCombo}"
                                          SelectionChanged="ViewModeCombo_SelectionChanged"
                                          ToolTip="Switch source list between List, Details, and Thumbnails view">
                                    <ComboBoxItem Content="List"/>
                                    <ComboBoxItem Content="Details" IsSelected="True"/>
                                    <ComboBoxItem Content="Thumbnails"/>
                                </ComboBox>
                            </StackPanel>

                            <!-- (UX R3) Live thumb-size slider. Only visible in Thumbnails view.
                                 60..240 px maps directly to AppSettings.ThumbnailSize and persists. -->
                            <StackPanel x:Name="ThumbSizePanel" Orientation="Horizontal"
                                        VerticalAlignment="Center"
                                        Visibility="Collapsed">
                                <TextBlock Text="Size:" Style="{StaticResource SourceFieldLabel}"/>
                                <Slider x:Name="ThumbSizeSlider" Width="110" VerticalAlignment="Center"
                                        Minimum="60" Maximum="240" SmallChange="10" LargeChange="20"
                                        IsSnapToTickEnabled="True" TickFrequency="10"
                                        Style="{StaticResource ToolSlider}"
                                        ValueChanged="ThumbSizeSlider_ValueChanged"
                                        ToolTip="Drag to resize thumbnail tiles (60–240 px)"/>
                                <TextBlock x:Name="ThumbSizeValue" VerticalAlignment="Center" Margin="6,0,0,0"
                                           MinWidth="36" TextAlignment="Right"
                                           Foreground="{DynamicResource MutedForeground}"/>
                            </StackPanel>

                            <Separator Style="{StaticResource VToolbarSeparator}"/>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Sort:" Style="{StaticResource SourceFieldLabel}"/>
                                <ComboBox x:Name="SortKeyCombo" Width="110"
                                          Style="{StaticResource SourceFieldCombo}"
                                          SelectionChanged="SortKeyCombo_SelectionChanged"
                                          ToolTip="Sort the source list by this property">
                                    <ComboBoxItem Content="Name" IsSelected="True"/>
                                    <ComboBoxItem Content="Size"/>
                                    <ComboBoxItem Content="Aspect"/>
                                    <ComboBoxItem Content="Modified"/>
                                    <ComboBoxItem Content="Kind"/>
                                    <ComboBoxItem Content="Duration"/>
                                    <ComboBoxItem Content="Created"/>
                                </ComboBox>
                                <Button x:Name="SortDirButton" Content="▲" Width="30" MinWidth="30"
                                        Style="{StaticResource NavToolButton}"
                                        Click="SortDir_Click"
                                        ToolTip="Toggle sort direction"/>
                            </StackPanel>

                            <Separator Style="{StaticResource VToolbarSeparator}"/>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Date:" Style="{StaticResource SourceFieldLabel}"/>
                                <ComboBox x:Name="DateFilterCombo" Width="120"
                                          Style="{StaticResource SourceFieldCombo}"
                                          SelectionChanged="DateFilterCombo_SelectionChanged"
                                          ToolTip="Limit the source list to files modified within this time range">
                                    <ComboBoxItem Content="All time" IsSelected="True"/>
                                    <ComboBoxItem Content="Last 7 days"/>
                                    <ComboBoxItem Content="Last 30 days"/>
                                    <ComboBoxItem Content="This year"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Aspect:" Style="{StaticResource SourceFieldLabel}"/>
                                <ComboBox x:Name="AspectFilterCombo" Width="110"
                                          Style="{StaticResource SourceFieldCombo}"
                                          SelectionChanged="AspectFilterCombo_SelectionChanged"
                                          ToolTip="Filter by image/video orientation (Portrait, Landscape, Square)">
                                    <ComboBoxItem Content="Any" IsSelected="True"/>
                                    <ComboBoxItem Content="Portrait"/>
                                    <ComboBoxItem Content="Landscape"/>
                                    <ComboBoxItem Content="Square"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Min ★:" Style="{StaticResource SourceFieldLabel}"/>
                                <ComboBox x:Name="MinRatingCombo" Width="70"
                                          Style="{StaticResource SourceFieldCombo}"
                                          SelectionChanged="MinRatingCombo_SelectionChanged"
                                          ToolTip="Show only items rated at least this many stars">
                                    <ComboBoxItem Content="Any" IsSelected="True"/>
                                    <ComboBoxItem Content="≥1"/>
                                    <ComboBoxItem Content="≥2"/>
                                    <ComboBoxItem Content="≥3"/>
                                    <ComboBoxItem Content="≥4"/>
                                    <ComboBoxItem Content="5"/>
                                </ComboBox>
                            </StackPanel>

                            <Separator Style="{StaticResource VToolbarSeparator}"/>

                            <!-- Search group: label + textbox + clear button stay together. -->
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Search:" Style="{StaticResource SourceFieldLabel}"/>
                                <TextBox x:Name="SearchBox" Width="180"
                                         Style="{StaticResource SourceFieldText}"
                                         TextChanged="SearchBox_TextChanged"
                                         PreviewKeyDown="SearchBox_PreviewKeyDown"
                                         ToolTip="Filter the source list by file name (Ctrl+F to focus, Esc to clear)"/>
                                <Button Content="✕" Width="26" MinWidth="26"
                                        Style="{StaticResource SourceFieldClearButton}"
                                        Click="ClearSearch_Click" ToolTip="Clear"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="Tag:" Style="{StaticResource SourceFieldLabel}"/>
                                <TextBox x:Name="TagFilterBox" Width="120"
                                         Style="{StaticResource SourceFieldText}"
                                         TextChanged="TagFilterBox_TextChanged"
                                         ToolTip="Show only items containing this tag (substring, case-insensitive)"/>
                            </StackPanel>
                        </WrapPanel>
                    </Border>

                    <!-- (UX R4) Breadcrumb path bar: clickable folder segments for the
                         current source path. Click any segment to jump up to that folder.
                         Hidden when no source folder is set. RebuildBreadcrumb() in
                         MainWindow.xaml.cs populates this. -->
                    <Border x:Name="BreadcrumbBar" DockPanel.Dock="Top"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrushColor}"
                            BorderThickness="0,0,0,1"
                            Padding="6,3"
                            Visibility="Collapsed">
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <StackPanel x:Name="BreadcrumbPanel" Orientation="Horizontal"/>
                        </ScrollViewer>
                    </Border>

                    <!-- Active filter chips: each chip shows an active filter and clicking it
                         clears that single filter. The whole panel is collapsed when no filters
                         are active. RebuildFilterChips() in MainWindow.xaml.cs populates this. -->
                    <Border DockPanel.Dock="Top"
                            Background="{DynamicResource PanelBackground}"
                            BorderBrush="{DynamicResource BorderBrushColor}"
                            BorderThickness="0,0,0,1"
                            Padding="6,4"
                            x:Name="FilterChipsContainer"
                            Visibility="Collapsed">
                        <WrapPanel x:Name="FilterChipsPanel" Orientation="Horizontal"/>
                    </Border>

                    <Grid DockPanel.Dock="Bottom" Margin="6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Pos" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                        <Slider Grid.Column="1" x:Name="PositionSlider" Minimum="0" Maximum="0"
                                SmallChange="1" LargeChange="5" IsSnapToTickEnabled="True" TickFrequency="1"
                                Style="{StaticResource ToolSlider}"
                                ValueChanged="PositionSlider_ValueChanged"
                                ToolTip="Jump to a specific position in the source list"/>
                        <TextBlock Grid.Column="2" x:Name="PositionText" Text="0/0" VerticalAlignment="Center" Margin="6,0,0,0"
                                   Foreground="{DynamicResource MutedForeground}"/>
                    </Grid>

                    <Grid>
                        <ListBox x:Name="ListView_List"
                                 Visibility="Collapsed"
                                 Background="{DynamicResource PanelBackground}"
                                 Foreground="{DynamicResource PanelForeground}"
                                 BorderThickness="0"
                                 AlternationCount="2"
                                 SelectionMode="Extended"
                                 ContextMenu="{StaticResource MediaListContextMenu}"
                                 SelectionChanged="MediaList_SelectionChanged"
                                 KeyDown="MediaList_KeyDown"
                                 AllowDrop="True"
                                 DragEnter="MediaList_DragEnter"
                                 DragOver="MediaList_DragOver"
                                 Drop="MediaList_Drop">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal">
                                        <CheckBox VerticalAlignment="Center" Margin="0,0,6,0"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  ToolTip="Select this item"/>
                                        <TextBlock Text="{Binding StarGlyph}" Foreground="#F5C518"
                                                   FontWeight="Bold" VerticalAlignment="Center"
                                                   Margin="0,0,4,0"/>
                                        <TextBlock Text="{Binding FileName}" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <ListView x:Name="ListView_Details"
                                  Background="{DynamicResource PanelBackground}"
                                  Foreground="{DynamicResource PanelForeground}"
                                  BorderThickness="0"
                                  AlternationCount="2"
                                  SelectionMode="Extended"
                                  ContextMenu="{StaticResource MediaListContextMenu}"
                                  SelectionChanged="MediaList_SelectionChanged"
                                  KeyDown="MediaList_KeyDown"
                                  AllowDrop="True"
                                  DragEnter="MediaList_DragEnter"
                                  DragOver="MediaList_DragOver"
                                  Drop="MediaList_Drop">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem" BasedOn="{StaticResource {x:Type ListViewItem}}">
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.View>
                                <GridView>
                                    <GridViewColumn Width="32">
                                        <GridViewColumnHeader Content=""/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <CheckBox HorizontalAlignment="Center"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          ToolTip="Select this item"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="24">
                                        <GridViewColumnHeader Content="★" ToolTip="Favorite"/>
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding StarGlyph}" Foreground="#F5C518"
                                                           FontWeight="Bold" HorizontalAlignment="Center"/>
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn Width="180" DisplayMemberBinding="{Binding FileName}">
                                        <GridViewColumnHeader Content="Name" Tag="Name" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="80" DisplayMemberBinding="{Binding SizeDisplay}">
                                        <GridViewColumnHeader Content="Size" Tag="Size" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding AspectDisplay}">
                                        <GridViewColumnHeader Content="Aspect" Tag="Aspect" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="70" DisplayMemberBinding="{Binding DurationDisplay}">
                                        <GridViewColumnHeader Content="Duration" Tag="Duration" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding ModifiedDate, StringFormat=yyyy-MM-dd HH:mm}">
                                        <GridViewColumnHeader Content="Modified" Tag="Modified" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                    <GridViewColumn Width="120" DisplayMemberBinding="{Binding CreatedDate, StringFormat=yyyy-MM-dd HH:mm}">
                                        <GridViewColumnHeader Content="Created" Tag="Created" Click="GridHeader_Click"/>
                                    </GridViewColumn>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <ListBox x:Name="ListView_Thumbs"
                                 Background="{DynamicResource PanelBackground}"
                                 Foreground="{DynamicResource PanelForeground}"
                                 BorderThickness="0"
                                 SelectionMode="Extended"
                                 ContextMenu="{StaticResource MediaListContextMenu}"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ScrollViewer.CanContentScroll="True"
                                 VirtualizingPanel.IsVirtualizing="True"
                                 VirtualizingPanel.VirtualizationMode="Recycling"
                                 VirtualizingPanel.CacheLengthUnit="Item"
                                 VirtualizingPanel.CacheLength="50"
                                 SelectionChanged="MediaList_SelectionChanged"
                                 KeyDown="MediaList_KeyDown"
                                 AllowDrop="True"
                                 DragEnter="MediaList_DragEnter"
                                 DragOver="MediaList_DragOver"
                                 Drop="MediaList_Drop">

                            <!-- Use the well-tested WpfToolkit VirtualizingWrapPanel package.
                                 The stock WrapPanel doesn't virtualize; with 1,938 items every
                                 PropertyChanged fired measure on every tile and the UI felt
                                 sluggish even though CPU was low. This panel only realizes
                                 containers for the visible rows plus a small cache. -->
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <vwp:VirtualizingWrapPanel Orientation="Horizontal"
                                                               SpacingMode="Uniform"
                                                               StretchItems="False"/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem" BasedOn="{StaticResource {x:Type ListBoxItem}}">
                                    <Setter Property="HorizontalAlignment" Value="Center"/>
                                    <Setter Property="IsSelected" Value="{Binding IsSelected, Mode=TwoWay}"/>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Width="{DynamicResource ThumbTileSize}" Height="{DynamicResource ThumbTileHeight}" Margin="4"
                                            Background="{DynamicResource ItemBackground}"
                                            BorderBrush="{DynamicResource BorderBrushColor}" BorderThickness="1"
                                            UseLayoutRounding="True" SnapsToDevicePixels="True"
                                            ToolTip="{Binding FullPath}">
                                        <DockPanel>
                                            <TextBlock DockPanel.Dock="Bottom" Text="{Binding FileName}"
                                                       TextTrimming="CharacterEllipsis" TextAlignment="Center"
                                                       Foreground="{DynamicResource PanelForeground}" Margin="2"/>
                                            <Grid Background="{DynamicResource PreviewBackground}" Margin="2"
                                                  UseLayoutRounding="True" SnapsToDevicePixels="True">
                                                <!-- UseLayoutRounding+SnapsToDevicePixels eliminate the half-pixel jitter
                                                     that appeared when async thumbnail assigns triggered re-measure on
                                                     a Stretch=Uniform Image. RenderOptions.BitmapScalingMode=Linear
                                                     (cheaper than HighQuality) avoids per-layout WIC rescaling. -->
                                                <!-- (UX R5) Smooth fade-in when the thumbnail decode finishes.
                                                     Use a DataTrigger on Thumbnail==null so the visual state is
                                                     driven by the bound value rather than a one-shot Binding.TargetUpdated
                                                     event. The previous EventTrigger approach broke when WPF's
                                                     virtualizing panel recycled containers across folder switches:
                                                     if the new MediaItem's Thumbnail was assigned synchronously
                                                     (already in memory cache), TargetUpdated did not fire and the
                                                     Image stayed at Opacity=0 forever — looking like a missing thumb.
                                                     With a Style/DataTrigger, every time the bound Thumbnail flips
                                                     from null to non-null the fade-in plays, and on entry where
                                                     Thumbnail is already non-null the default Opacity=1 is in effect. -->
                                                <Image Source="{Binding Thumbnail}" Stretch="Uniform"
                                                       UseLayoutRounding="True" SnapsToDevicePixels="True"
                                                       RenderOptions.BitmapScalingMode="Linear"
                                                       RenderOptions.EdgeMode="Aliased">
                                                    <Image.Style>
                                                        <Style TargetType="Image">
                                                            <!-- Steady state is fully visible. When Thumbnail is null
                                                                 the Image has no Source and renders nothing anyway,
                                                                 so the glyph placeholder behind it shows through. -->
                                                            <Setter Property="Opacity" Value="1"/>
                                                            <Style.Triggers>
                                                                <!-- Fade in 0 → 1 over 150ms whenever Thumbnail flips
                                                                     from null to non-null (NullVis returns Visible
                                                                     when value is non-null). The Storyboard auto-stops
                                                                     at To=1 so the steady-state Setter takes over. -->
                                                                <DataTrigger Binding="{Binding Thumbnail, Converter={StaticResource NullVis}}" Value="Visible">
                                                                    <DataTrigger.EnterActions>
                                                                        <BeginStoryboard>
                                                                            <Storyboard>
                                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                                 From="0" To="1" Duration="0:0:0.15"/>
                                                                            </Storyboard>
                                                                        </BeginStoryboard>
                                                                    </DataTrigger.EnterActions>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Image.Style>
                                                </Image>
                                                <TextBlock Text="🎬" FontSize="32"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Kind, Converter={StaticResource KindVis}, ConverterParameter=Video}"/>
                                                <TextBlock Text="🖼" FontSize="32" Opacity="0.35"
                                                           Foreground="{DynamicResource MutedForeground}"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Visibility="{Binding Thumbnail, Converter={StaticResource NullVis}, ConverterParameter=Invert}"/>
                                                <Border Background="#CCFF6B6B" CornerRadius="3" Padding="4,1"
                                                        HorizontalAlignment="Right" VerticalAlignment="Top" Margin="2"
                                                        Visibility="{Binding IsDuplicate, Converter={StaticResource BoolVis}}">
                                                    <TextBlock Text="DUP" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                </Border>
                                                <CheckBox HorizontalAlignment="Left" VerticalAlignment="Top" Margin="4"
                                                          Style="{StaticResource ThumbTileCheckBox}"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                          ToolTip="Select this item"/>
                                                <TextBlock Text="{Binding StarGlyph}" Foreground="#F5C518"
                                                           FontWeight="Bold" FontSize="18"
                                                           HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                                           Margin="4"
                                                           Effect="{x:Null}"/>
                                            </Grid>
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <!-- (UX R5) Empty-state overlay shown on top of the (empty) list views.
                             Two messages, toggled by code-behind via SourceFolder text presence:
                               • No folder picked yet → "Drop a folder here, or press Ctrl+O"
                               • Folder picked but filtered/scanned to zero items → "No items match"
                             IsHitTestVisible=False so click+drop still passes through to the
                             ListBox below. Visibility is driven from code-behind in UpdateStats(). -->
                        <Grid x:Name="EmptyStateOverlay" Visibility="Collapsed"
                              IsHitTestVisible="False"
                              Background="Transparent">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                        MaxWidth="320">
                                <TextBlock x:Name="EmptyStateGlyph"
                                           Text="🗂"
                                           FontSize="56"
                                           HorizontalAlignment="Center"
                                           Opacity="0.45"
                                           Foreground="{DynamicResource MutedForeground}"
                                           Margin="0,0,0,12"/>
                                <TextBlock x:Name="EmptyStateTitle"
                                           Text="No source folder yet"
                                           FontSize="15"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           Foreground="{DynamicResource PanelForeground}"/>
                                <TextBlock x:Name="EmptyStateDetail"
                                           Text="Drop a folder here, or press Ctrl+O to pick one."
                                           FontSize="12"
                                           HorizontalAlignment="Center"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"
                                           Opacity="0.75"
                                           Foreground="{DynamicResource MutedForeground}"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="Splitter01" Grid.Column="1"
                          Style="{StaticResource GripSplitter}"
                          DragCompleted="PanelSplitter_DragCompleted"/>

            <!-- CENTER: Preview -->
            <Border x:Name="PreviewPane" Grid.Column="2"
                    Style="{StaticResource PaneFrameBorder}"
                    Background="{DynamicResource PreviewBackground}"
                    GotKeyboardFocus="Pane_GotKeyboardFocus"
                    PreviewMouseDown="Pane_PreviewMouseDown">
                <DockPanel>
                    <Border x:Name="PreviewPaneHeader" DockPanel.Dock="Top" Background="{DynamicResource PanelHeader}" Padding="8,4"
                            BorderBrush="{DynamicResource PreviewAccentStripe}" BorderThickness="0,3,0,0">
                        <DockPanel LastChildFill="True">
                            <!-- Right-docked button row goes FIRST so DockPanel reserves it.
                                 The TextBlock comes last and (with LastChildFill=True) fills
                                 the remaining space to the left, giving TextTrimming a finite
                                 width to clip against when filenames are long. -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="◀" Style="{StaticResource PaneToolButton}"
                                        Tag="Preview" Click="PaneMoveLeft_Click"
                                        MinWidth="24" Padding="6,2" Margin="0,0,2,0"
                                        ToolTip="Move this pane one slot to the left"/>
                                <Button Content="▶" Style="{StaticResource PaneToolButton}"
                                        Tag="Preview" Click="PaneMoveRight_Click"
                                        MinWidth="24" Padding="6,2" Margin="0,0,2,0"
                                        ToolTip="Move this pane one slot to the right"/>
                                <Button Content="✕" Style="{StaticResource PaneToolButton}"
                                        Tag="Preview" Click="PaneHide_Click"
                                        MinWidth="24" Padding="6,2"
                                        ToolTip="Hide this pane (use Panes▾ in toolbar to restore)"/>
                            </StackPanel>
                            <!-- 12px right margin gives breathing room before the buttons.
                                 ToolTip shows the full untruncated text on hover. -->
                            <TextBlock x:Name="PreviewTitle" Text="Preview" FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Margin="0,0,12,0"
                                       TextTrimming="CharacterEllipsis"
                                       ToolTip="{Binding Text, RelativeSource={RelativeSource Self}}"
                                       Foreground="{DynamicResource PanelForeground}"/>
                        </DockPanel>
                    </Border>

                    <Border DockPanel.Dock="Bottom" x:Name="VideoControls"
                            Background="{DynamicResource PanelBackground}" Padding="8,6"
                            Visibility="Collapsed">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal">
                                <Button Content="▶/⏸" Width="46" Style="{StaticResource ActionToolButton}" Click="VideoTogglePlay_Click" ToolTip="Play / Pause (Space)"/>
                                <Button Content="⏹" Width="32" Style="{StaticResource ActionToolButton}" Click="VideoStop_Click"
                                        ToolTip="Stop playback"/>
                                <ToggleButton x:Name="LoopToggle" Content="↻" Width="32" Margin="4,0,0,0"
                                              Style="{StaticResource ToolToggleButton}"
                                              ToolTip="Loop"/>
                                <!-- (#20) Audio preview: mute toggle + volume slider. M toggles mute. -->
                                <ToggleButton x:Name="MuteToggle" Content="🔊" Width="32" Margin="8,0,0,0"
                                              Style="{StaticResource ToolToggleButton}"
                                              ToolTip="Mute / unmute (M)" Click="MuteToggle_Click"/>
                                <Slider x:Name="VolumeSlider" Width="90" Minimum="0" Maximum="100"
                                        Margin="6,0,0,0" VerticalAlignment="Center"
                                        Style="{StaticResource ToolSlider}"
                                        ToolTip="Volume (0–100)"
                                        ValueChanged="VolumeSlider_ValueChanged"/>
                            </StackPanel>
                            <TextBlock DockPanel.Dock="Right" x:Name="VideoTimeText" Text="0:00 / 0:00"
                                       VerticalAlignment="Center" Margin="8,0,0,0"
                                       Foreground="{DynamicResource MutedForeground}"/>
                            <Slider x:Name="VideoScrub" Minimum="0" Maximum="1000" Margin="10,0"
                                    VerticalAlignment="Center"
                                    Style="{StaticResource ToolSlider}"
                                    Thumb.DragStarted="VideoScrub_DragStarted"
                                    Thumb.DragCompleted="VideoScrub_DragCompleted"
                                    PreviewMouseDown="VideoScrub_PreviewMouseDown"/>
                        </DockPanel>
                    </Border>

                    <Grid x:Name="PreviewArea" ClipToBounds="True">
                        <ScrollViewer x:Name="PreviewScroll" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                            <Image x:Name="PreviewImage" Stretch="Uniform" Margin="10" Visibility="Collapsed"
                                   UseLayoutRounding="True" SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"
                                   MaxWidth="{Binding ViewportWidth, ElementName=PreviewScroll}"
                                   MaxHeight="{Binding ViewportHeight, ElementName=PreviewScroll}"
                                   MouseWheel="PreviewImage_MouseWheel"
                                   MouseLeftButtonDown="PreviewImage_MouseDown"
                                   MouseLeftButtonUp="PreviewImage_MouseUp"
                                   MouseMove="PreviewImage_MouseMove">
                                <Image.LayoutTransform>
                                    <!-- Default zoom is 90% so loaded images don't push against the
                                         viewport edges; user can press 0 to reset (also 90%) or
                                         scroll-wheel to zoom in/out. -->
                                    <ScaleTransform x:Name="PreviewImageScale" ScaleX="0.9" ScaleY="0.9"/>
                                </Image.LayoutTransform>
                            </Image>
                        </ScrollViewer>
                        <vlc:VideoView x:Name="PreviewVideo" Margin="10" Visibility="Collapsed"/>
                        <TextBlock x:Name="PreviewEmpty" Text="Select a media file to preview"
                                   Foreground="{DynamicResource EmptyForeground}" FontSize="16"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </DockPanel>
            </Border>

            <GridSplitter x:Name="Splitter12" Grid.Column="3"
                          Style="{StaticResource GripSplitter}"
                          Background="{DynamicResource SplitterBrush}"
                          DragCompleted="PanelSplitter_DragCompleted"/>

            <!-- RIGHT: Destinations + EXIF -->
            <Border x:Name="DestinationsPane" Grid.Column="4"
                    Style="{StaticResource PaneFrameBorder}"
                    Background="{DynamicResource PanelBackground}"
                    GotKeyboardFocus="Pane_GotKeyboardFocus"
                    PreviewMouseDown="Pane_PreviewMouseDown">
                <DockPanel>
                    <Border x:Name="DestinationsPaneHeader" DockPanel.Dock="Top" Background="{DynamicResource PanelHeader}" Padding="8,4"
                            BorderBrush="{DynamicResource DestinationAccentStripe}" BorderThickness="0,3,0,0">
                        <DockPanel LastChildFill="True">
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Content="+ Add" Style="{StaticResource ActionToolButton}" Click="AddDestination_Click"
                                        ToolTip="Add a new destination button (folder + hotkey)" Margin="0,0,4,0"/>
                                <Separator Margin="2,0,4,0"/>
                                <Button Content="◀" Style="{StaticResource PaneToolButton}"
                                        Tag="Destinations" Click="PaneMoveLeft_Click"
                                        MinWidth="24" Padding="6,2" Margin="0,0,2,0"
                                        ToolTip="Move this pane one slot to the left"/>
                                <Button Content="▶" Style="{StaticResource PaneToolButton}"
                                        Tag="Destinations" Click="PaneMoveRight_Click"
                                        MinWidth="24" Padding="6,2" Margin="0,0,2,0"
                                        ToolTip="Move this pane one slot to the right"/>
                                <Button Content="✕" Style="{StaticResource PaneToolButton}"
                                        Tag="Destinations" Click="PaneHide_Click"
                                        MinWidth="24" Padding="6,2"
                                        ToolTip="Hide this pane (use Panes▾ in toolbar to restore)"/>
                            </StackPanel>
                            <TextBlock Text="Destinations" FontWeight="Bold"
                                       Foreground="{DynamicResource PanelForeground}" VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <!-- EXIF / file info section pinned to bottom -->
                    <Expander DockPanel.Dock="Bottom" Header="File info / EXIF" IsExpanded="False"
                              Foreground="{DynamicResource PanelForeground}" Margin="6,4">
                        <ItemsControl x:Name="ExifItems" Margin="6,4">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Key}" Foreground="{DynamicResource MutedForeground}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Value}" TextWrapping="Wrap"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </Expander>

                    <!-- (#5) Virtualized destinations: ItemsControl with its own ScrollViewer
                         and a VirtualizingStackPanel so 100s of dests scroll smoothly. -->
                    <ItemsControl x:Name="DestinationsPanel"
                                  VirtualizingStackPanel.IsVirtualizing="True"
                                  VirtualizingStackPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True"
                                  ScrollViewer.VerticalScrollBarVisibility="Auto"
                                  ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ItemsControl.Template>
                                <ControlTemplate TargetType="ItemsControl">
                                    <Border Background="{TemplateBinding Background}"
                                            BorderBrush="{TemplateBinding BorderBrush}"
                                            BorderThickness="{TemplateBinding BorderThickness}">
                                        <ScrollViewer Focusable="False"
                                                      CanContentScroll="True"
                                                      VerticalScrollBarVisibility="Auto"
                                                      HorizontalScrollBarVisibility="Disabled">
                                            <ItemsPresenter/>
                                        </ScrollViewer>
                                    </Border>
                                </ControlTemplate>
                            </ItemsControl.Template>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <!-- Multi-column wrap layout. Tiles use DestTileWidth so the
                                         panel flows them into as many columns as fit. The wider
                                         the user makes the destinations panel, the more columns
                                         appear. Vertical scroll kicks in when rows overflow. -->
                                    <vwp:VirtualizingWrapPanel IsItemsHost="True"
                                                               Orientation="Horizontal"
                                                               SpacingMode="None"
                                                               StretchItems="False"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="6,4" Tag="{Binding}"
                                          Width="{DynamicResource DestTileWidth}">
                                        <!-- (UX R5) Hotkey-pulse glow: a soft outer ring that fades in/out
                                             on each destination-key press so the user sees instant visual
                                             confirmation that their keystroke landed on the right tile,
                                             even before the actual move completes (which on a network
                                             share can take seconds). PulseOpacity is animated 0→1→0 over
                                             ~330ms by PulseDestination(). Sits BEHIND the main tile
                                             border (z-order = render order), inflated by 3px on every
                                             side via negative margin so it reads as a halo. -->
                                        <Border Margin="-3"
                                                CornerRadius="4"
                                                Background="#33FFA000"
                                                BorderBrush="#FFA000"
                                                BorderThickness="2"
                                                IsHitTestVisible="False"
                                                Opacity="{Binding PulseOpacity}"/>
                                        <Border Background="{DynamicResource ItemBackground}"
                                                BorderBrush="{DynamicResource BorderBrushColor}"
                                                BorderThickness="1" Padding="6"
                                                Tag="{Binding}">
                                            <DockPanel>
                                                <!-- Per-destination accent tint (4px strip on the far left). Transparent fill when no tint set. -->
                                                <Rectangle DockPanel.Dock="Left" Width="4" Margin="0,0,4,0"
                                                           Fill="{Binding AccentBrush}"
                                                           IsHitTestVisible="False"/>
                                                <!-- (#10) Click-and-hold drag handle. Press, hold, drag up/down to reorder. -->
                                                <Border DockPanel.Dock="Left" Width="14" Margin="0,0,4,0"
                                                        Background="Transparent" Cursor="SizeAll"
                                                        ToolTip="Click and hold, then drag up or down to reorder"
                                                        Tag="{Binding}"
                                                        PreviewMouseLeftButtonDown="DragHandle_PreviewMouseLeftButtonDown">
                                                    <TextBlock Text="⋮⋮" FontSize="14" FontWeight="Bold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{DynamicResource MutedForeground}"
                                                               IsHitTestVisible="False"/>
                                                </Border>
                                                <Button Style="{StaticResource DestButton}" Click="SendToDestination_Click" Tag="{Binding}"
                                                        Opacity="{Binding BadgeOpacity}"
                                                        ToolTip="Click: send selected items here&#x0A;Ctrl+Click: open this folder in Explorer&#x0A;Right-click: more actions">
                                                    <Button.ContextMenu>
                                                        <ContextMenu>
                                                            <MenuItem Header="Open folder in Explorer" Tag="{Binding}" Click="OpenDestFolder_Click"/>
                                                            <MenuItem Header="Use as source folder" Tag="{Binding}" Click="UseDestAsSource_Click"/>
                                                            <MenuItem Header="Copy folder path" Tag="{Binding}" Click="CopyDestPath_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Move up" Tag="{Binding}" Click="MoveDestUp_Click"/>
                                                            <MenuItem Header="Move down" Tag="{Binding}" Click="MoveDestDown_Click"/>
                                                            <MenuItem Header="Sort destinations A–Z" Click="SortDestinationsAlpha_Click"/>
                                                            <Separator/>
                                                            <MenuItem Header="Edit destination..." Tag="{Binding}" Click="EditDestination_Click"/>
                                                            <MenuItem Header="Remove destination" Tag="{Binding}" Click="RemoveDestination_Click"/>
                                                        </ContextMenu>
                                                    </Button.ContextMenu>
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Name}" FontWeight="Bold"
                                                                   FontFamily="{DynamicResource DestNameFontFamily}"
                                                                   FontSize="{DynamicResource DestNameFontSize}"/>
                                                        <TextBlock Text="{Binding HotKeyDisplay}" Opacity="0.8"
                                                                   FontFamily="{DynamicResource DestKeyFontFamily}"
                                                                   FontSize="{DynamicResource DestKeyFontSize}"/>
                                                        <TextBlock Text="{Binding FolderPath}" Opacity="0.7" TextTrimming="CharacterEllipsis"
                                                                   FontFamily="{DynamicResource DestPathFontFamily}"
                                                                   FontSize="{DynamicResource DestPathFontSize}"/>
                                                        <TextBlock Text="{Binding BadgeText}" Opacity="0.65" FontStyle="Italic"
                                                                   FontFamily="{DynamicResource DestBadgeFontFamily}"
                                                                   FontSize="{DynamicResource DestBadgeFontSize}"/>
                                                        <TextBlock Text="{Binding StatusGlyph}" ToolTip="{Binding StatusGlyphTooltip}"
                                                                   FontSize="10" FontWeight="Bold" Foreground="#E07A28"/>
                                                    </StackPanel>
                                                </Button>
                                            </DockPanel>
                                        </Border>
                                        <!-- Transient "+N" flash badge after a successful move (top-right). -->
                                        <Border HorizontalAlignment="Right" VerticalAlignment="Top"
                                                Margin="0,-6,-6,0" Padding="7,2"
                                                CornerRadius="10"
                                                Background="#1FA463"
                                                BorderBrush="White" BorderThickness="1"
                                                IsHitTestVisible="False"
                                                Opacity="{Binding FlashOpacity}">
                                            <TextBlock Text="{Binding FlashBadge}"
                                                       Foreground="White" FontWeight="Bold" FontSize="12"/>
                                        </Border>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>

    <!-- Overlay layer for fly-to-destination animations -->
    <Canvas x:Name="AnimationOverlay" IsHitTestVisible="False" Background="Transparent"/>

    <!-- Keyboard shortcut overlay. Toggled by ? / F1, dismissed with Esc or click-outside-card. -->
    <local:ShortcutOverlay x:Name="KeyboardOverlay"
                           xmlns:local="clr-namespace:MediaSort.Views"/>
    </Grid>
</Window>
