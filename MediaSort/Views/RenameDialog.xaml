<Window x:Class="MediaSort.Views.RenameDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Rename"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="220" Width="460"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Rename file" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

        <TextBlock Grid.Row="1" x:Name="CurrentNameText" TextTrimming="CharacterEllipsis"
                   Foreground="{DynamicResource MutedForeground}" Margin="0,0,0,8"/>

        <TextBox Grid.Row="2" x:Name="NameBox" Padding="6"
                 Background="{DynamicResource InputBackground}"
                 Foreground="{DynamicResource PanelForeground}"
                 BorderBrush="{DynamicResource ButtonBorder}"
                 KeyDown="NameBox_KeyDown"/>

        <TextBlock Grid.Row="3" x:Name="ErrorText" Foreground="#E04F4F" FontSize="11"
                   TextWrapping="Wrap" Margin="0,6,0,0"/>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <CheckBox x:Name="EditExtensionCheck" Content="Edit extension" VerticalAlignment="Center"
                      Foreground="{DynamicResource PanelForeground}" Margin="0,0,12,0"
                      Checked="EditExtension_Toggled" Unchecked="EditExtension_Toggled"/>
            <Button Content="Cancel" Width="90" Margin="4,0" IsCancel="True" Click="Cancel_Click"/>
            <Button Content="Rename" Width="90" Margin="4,0" IsDefault="True" Click="Ok_Click"/>
        </StackPanel>
    </Grid>
</Window>
