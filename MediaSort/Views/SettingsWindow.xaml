<Window x:Class="MediaSort.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaSort Settings"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="720" Width="680"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolButton}" Click="Cancel_Click" Width="90" ToolTip="Discard changes and close"/>
            <Button Content="OK" Style="{StaticResource ToolButton}" Click="Ok_Click" Width="90" Margin="6,0,0,0" ToolTip="Save changes and close"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="General" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Source folder" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <TextBox Grid.Column="1" x:Name="SourceFolderBox" Padding="4"
                             Background="{DynamicResource InputBackground}"
                             Foreground="{DynamicResource PanelForeground}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             ToolTip="The folder MediaSort scans for media files to sort"/>
                    <Button Grid.Column="2" Content="Browse..." Style="{StaticResource ToolButton}" Click="BrowseSource_Click" ToolTip="Pick the source folder"/>
                </Grid>

                <CheckBox x:Name="RecursiveCheck" Content="Scan subfolders (recursive)" Margin="0,0,0,8"
                          Foreground="{DynamicResource PanelForeground}"
                          ToolTip="Include nested folders when scanning the source folder"/>

                <CheckBox x:Name="AutoAdvanceCheck" Content="Auto-advance to next item after move" Margin="0,0,0,16"
                          Foreground="{DynamicResource PanelForeground}"
                          ToolTip="After sending a file to a destination, automatically select the next item"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Default view" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox Grid.Column="1" x:Name="ViewModeCombo"
                              ToolTip="Initial view mode for the source list when MediaSort starts">
                        <ComboBoxItem Content="List"/>
                        <ComboBoxItem Content="Details"/>
                        <ComboBoxItem Content="Thumbnails"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Conflict policy" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox Grid.Column="1" x:Name="ConflictPolicyCombo"
                              ToolTip="What to do when a destination already has a file with the same name">
                        <ComboBoxItem Content="Prompt each time"/>
                        <ComboBoxItem Content="Always rename"/>
                        <ComboBoxItem Content="Always overwrite"/>
                        <ComboBoxItem Content="Always skip"/>
                    </ComboBox>
                </Grid>

                <TextBlock Text="Appearance" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Theme" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox Grid.Column="1" x:Name="ThemeCombo"
                              ToolTip="Override the app theme. 'Follow system' matches Windows light/dark mode.">
                        <ComboBoxItem Content="Follow system"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Accent color (hex)" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <TextBox Grid.Column="1" x:Name="AccentBox" Padding="4"
                             Background="{DynamicResource InputBackground}"
                             Foreground="{DynamicResource PanelForeground}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             TextChanged="AccentBox_TextChanged"
                             ToolTip="Hex color (e.g. #2D7BD4) used for destination buttons, selection, and highlights"/>
                    <Border Grid.Column="2" x:Name="AccentSwatch" Width="30" Height="22" Margin="6,0,0,0"
                            BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1" CornerRadius="3"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Animation speed" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="How long the source-to-destination fly animation lasts (milliseconds)"/>
                    <Slider Grid.Column="1" x:Name="AnimationSlider"
                            Minimum="60" Maximum="1200" SmallChange="20" LargeChange="100"
                            TickFrequency="100" IsSnapToTickEnabled="False"
                            ValueChanged="AnimationSlider_ValueChanged"
                            ToolTip="Drag to set animation duration (60ms = snappy, 1200ms = leisurely)"/>
                    <TextBlock Grid.Column="2" x:Name="AnimationValueText" VerticalAlignment="Center"
                               TextAlignment="Right" Margin="6,0,0,0"
                               Foreground="{DynamicResource MutedForeground}"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Thumbnail size" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="Size in pixels of each tile in the Thumbnails view"/>
                    <Slider Grid.Column="1" x:Name="ThumbSizeSlider"
                            Minimum="60" Maximum="240" SmallChange="10" LargeChange="30"
                            TickFrequency="20" IsSnapToTickEnabled="False"
                            ValueChanged="ThumbSizeSlider_ValueChanged"
                            ToolTip="Drag to resize the thumbnail tiles (60px = compact, 240px = large)"/>
                    <TextBlock Grid.Column="2" x:Name="ThumbSizeValueText" VerticalAlignment="Center"
                               TextAlignment="Right" Margin="6,0,0,0"
                               Foreground="{DynamicResource MutedForeground}"/>
                </Grid>

                <TextBlock Text="Destinations" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>
                <TextBlock Text="Use the + Add and ✎ Edit buttons in the main window. Listed here for reference."
                           Foreground="{DynamicResource MutedForeground}" Margin="0,0,0,4"/>
                <ListBox x:Name="DestinationsList" Height="160"
                         Background="{DynamicResource PanelBackground}"
                         Foreground="{DynamicResource PanelForeground}"
                         BorderBrush="{DynamicResource ButtonBorder}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding FolderPath}" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding HotKeyDisplay}" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
