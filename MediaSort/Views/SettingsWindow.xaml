<Window x:Class="MediaSort.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaSort Settings"
        Height="520" Width="640"
        Background="#1E1E1E"
        Foreground="#EEE"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolButton}" Click="Cancel_Click" Width="90"/>
            <Button Content="OK" Style="{StaticResource ToolButton}" Click="Ok_Click" Width="90" Margin="6,0,0,0"/>
        </StackPanel>

        <TextBlock DockPanel.Dock="Top" Text="General" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>

        <StackPanel>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Source folder" VerticalAlignment="Center"/>
                <TextBox Grid.Column="1" x:Name="SourceFolderBox" Padding="4" Background="#2A2A2A" Foreground="#EEE" BorderBrush="#444"/>
                <Button Grid.Column="2" Content="Browse..." Style="{StaticResource ToolButton}" Click="BrowseSource_Click"/>
            </Grid>

            <CheckBox x:Name="RecursiveCheck" Content="Scan subfolders (recursive)" Margin="0,0,0,8" Foreground="#DDD"/>

            <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="Default view" VerticalAlignment="Center"/>
                <ComboBox Grid.Column="1" x:Name="ViewModeCombo">
                    <ComboBoxItem Content="List"/>
                    <ComboBoxItem Content="Details"/>
                    <ComboBoxItem Content="Thumbnails"/>
                </ComboBox>
            </Grid>

            <TextBlock Text="Destinations" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"/>
            <TextBlock Text="Use the + Add and ✎ Edit buttons in the main window. Listed here for reference." Opacity="0.7" Margin="0,0,0,4"/>
            <ListBox x:Name="DestinationsList" Height="200" Background="#1E1E1E" Foreground="#DDD" BorderBrush="#444">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                            <TextBlock Text="{Binding FolderPath}" Opacity="0.7" FontSize="11"/>
                            <TextBlock Text="{Binding HotKeyDisplay}" Opacity="0.7" FontSize="11"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </StackPanel>
    </DockPanel>
</Window>
