<Window x:Class="MediaSort.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MediaSort Settings"
        Icon="pack://application:,,,/Assets/AppIcon.ico"
        Height="720" Width="680"
        Background="{DynamicResource WindowBackground}"
        Foreground="{DynamicResource PanelForeground}"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Cancel" Style="{StaticResource ToolButton}" Click="Cancel_Click" Width="90" ToolTip="Discard changes and close"/>
            <Button Content="OK" Style="{StaticResource PrimaryToolButton}" Click="Ok_Click" Width="90" Margin="6,0,0,0" ToolTip="Save changes and close"/>
        </StackPanel>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <TextBlock Text="General" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Source folder" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <TextBox Grid.Column="1" x:Name="SourceFolderBox" Padding="4"
                             Background="{DynamicResource InputBackground}"
                             Foreground="{DynamicResource PanelForeground}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             ToolTip="The folder MediaSort scans for media files to sort"/>
                    <Button Grid.Column="2" Content="Browse..." Style="{StaticResource SourceToolButton}" Click="BrowseSource_Click" ToolTip="Pick the source folder"/>
                </Grid>

                <CheckBox x:Name="RecursiveCheck" Content="Scan subfolders (recursive)" Margin="0,0,0,8"
                          Foreground="{DynamicResource PanelForeground}"
                          ToolTip="Include nested folders when scanning the source folder"/>

                <CheckBox x:Name="IncludeHiddenCheck" Content="Include hidden and system files" Margin="0,0,0,8"
                          Foreground="{DynamicResource PanelForeground}"
                          ToolTip="Off by default. Skips files/folders with the Hidden or System attribute (e.g. AppData, $RECYCLE.BIN, .git)."/>

                <CheckBox x:Name="AutoAdvanceCheck" Content="Auto-advance to next item after move" Margin="0,0,0,8"
                          Foreground="{DynamicResource PanelForeground}"
                          ToolTip="After sending a file to a destination, automatically select the next item"/>

                <CheckBox x:Name="ExportDragDropCheck" Content="Drag files out to Explorer and other apps" Margin="0,0,0,16"
                          Foreground="{DynamicResource PanelForeground}"
                          ToolTip="When on, you can grab a thumbnail or list row and drag it out of MediaSort to copy the file into Explorer, Photoshop, a chat client, etc."/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Default view" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox Grid.Column="1" x:Name="ViewModeCombo"
                              ToolTip="Initial view mode for the source list when MediaSort starts">
                        <ComboBoxItem Content="List"/>
                        <ComboBoxItem Content="Details"/>
                        <ComboBoxItem Content="Thumbnails"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Conflict policy" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox Grid.Column="1" x:Name="ConflictPolicyCombo"
                              ToolTip="What to do when a destination already has a file with the same name">
                        <ComboBoxItem Content="Prompt each time"/>
                        <ComboBoxItem Content="Always rename"/>
                        <ComboBoxItem Content="Always overwrite"/>
                        <ComboBoxItem Content="Always skip"/>
                    </ComboBox>
                </Grid>

                <TextBlock Text="Appearance" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Theme" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <ComboBox Grid.Column="1" x:Name="ThemeCombo"
                              ToolTip="Override the app theme. 'Follow system' matches Windows light/dark mode.">
                        <ComboBoxItem Content="Follow system"/>
                        <ComboBoxItem Content="Light"/>
                        <ComboBoxItem Content="Dark"/>
                    </ComboBox>
                </Grid>

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Accent color (hex)" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"/>
                    <TextBox Grid.Column="1" x:Name="AccentBox" Padding="4"
                             Background="{DynamicResource InputBackground}"
                             Foreground="{DynamicResource PanelForeground}"
                             BorderBrush="{DynamicResource ButtonBorder}"
                             TextChanged="AccentBox_TextChanged"
                             ToolTip="Hex color (e.g. #2D7BD4) used for destination buttons, selection, and highlights"/>
                    <Border Grid.Column="2" x:Name="AccentSwatch" Width="30" Height="22" Margin="6,0,0,0"
                            BorderBrush="{DynamicResource ButtonBorder}" BorderThickness="1" CornerRadius="3"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Animation speed" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="How long the source-to-destination fly animation lasts (milliseconds)"/>
                    <Slider Grid.Column="1" x:Name="AnimationSlider"
                            Minimum="60" Maximum="1200" SmallChange="20" LargeChange="100"
                            TickFrequency="100" IsSnapToTickEnabled="False"
                            ValueChanged="AnimationSlider_ValueChanged"
                            ToolTip="Drag to set animation duration (60ms = snappy, 1200ms = leisurely)"/>
                    <TextBlock Grid.Column="2" x:Name="AnimationValueText" VerticalAlignment="Center"
                               TextAlignment="Right" Margin="6,0,0,0"
                               Foreground="{DynamicResource MutedForeground}"/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Thumbnail size" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="Size in pixels of each tile in the Thumbnails view"/>
                    <Slider Grid.Column="1" x:Name="ThumbSizeSlider"
                            Minimum="60" Maximum="240" SmallChange="10" LargeChange="30"
                            TickFrequency="20" IsSnapToTickEnabled="False"
                            ValueChanged="ThumbSizeSlider_ValueChanged"
                            ToolTip="Drag to resize the thumbnail tiles (60px = compact, 240px = large)"/>
                    <TextBlock Grid.Column="2" x:Name="ThumbSizeValueText" VerticalAlignment="Center"
                               TextAlignment="Right" Margin="6,0,0,0"
                               Foreground="{DynamicResource MutedForeground}"/>
                </Grid>

                <TextBlock Text="Destination button text" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>
                <TextBlock Text="Pick a font and size for each line shown on every destination button. Leave the family blank to use the system default (Segoe UI). Sizes are in pixels (6–48)."
                           Foreground="{DynamicResource MutedForeground}" TextWrapping="Wrap" Margin="0,0,0,8"/>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="90"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Header row -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Line" FontWeight="Bold" Margin="0,0,0,4"
                               Foreground="{DynamicResource MutedForeground}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Font family" FontWeight="Bold" Margin="6,0,6,4"
                               Foreground="{DynamicResource MutedForeground}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="Size (px)" FontWeight="Bold" Margin="0,0,0,4"
                               Foreground="{DynamicResource MutedForeground}"/>

                    <!-- Folder name -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Folder name" VerticalAlignment="Center" Margin="0,2"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="The bold top line of each destination button (the destination's display name)."/>
                    <ComboBox Grid.Row="1" Grid.Column="1" x:Name="DestNameFontCombo" IsEditable="True" Margin="6,2"
                              ToolTip="Type or pick any installed font. Empty = Segoe UI."/>
                    <TextBox  Grid.Row="1" Grid.Column="2" x:Name="DestNameSizeBox" Padding="4" Margin="0,2"
                              Background="{DynamicResource InputBackground}"
                              Foreground="{DynamicResource PanelForeground}"
                              BorderBrush="{DynamicResource ButtonBorder}"
                              ToolTip="Font size in pixels (6–48)."/>

                    <!-- Hotkey -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Key / shortcut" VerticalAlignment="Center" Margin="0,2"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="The hotkey line, e.g. '1', 'Ctrl+2'."/>
                    <ComboBox Grid.Row="2" Grid.Column="1" x:Name="DestKeyFontCombo" IsEditable="True" Margin="6,2"
                              ToolTip="Type or pick any installed font. Empty = Segoe UI."/>
                    <TextBox  Grid.Row="2" Grid.Column="2" x:Name="DestKeySizeBox" Padding="4" Margin="0,2"
                              Background="{DynamicResource InputBackground}"
                              Foreground="{DynamicResource PanelForeground}"
                              BorderBrush="{DynamicResource ButtonBorder}"
                              ToolTip="Font size in pixels (6–48)."/>

                    <!-- Folder path -->
                    <TextBlock Grid.Row="3" Grid.Column="0" Text="Folder path" VerticalAlignment="Center" Margin="0,2"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="The full destination path line (truncated with … if too long)."/>
                    <ComboBox Grid.Row="3" Grid.Column="1" x:Name="DestPathFontCombo" IsEditable="True" Margin="6,2"
                              ToolTip="Type or pick any installed font. Empty = Segoe UI."/>
                    <TextBox  Grid.Row="3" Grid.Column="2" x:Name="DestPathSizeBox" Padding="4" Margin="0,2"
                              Background="{DynamicResource InputBackground}"
                              Foreground="{DynamicResource PanelForeground}"
                              BorderBrush="{DynamicResource ButtonBorder}"
                              ToolTip="Font size in pixels (6–48)."/>

                    <!-- File count badge -->
                    <TextBlock Grid.Row="4" Grid.Column="0" Text="File count" VerticalAlignment="Center" Margin="0,2"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="The italic last line showing the number of files in the destination folder."/>
                    <ComboBox Grid.Row="4" Grid.Column="1" x:Name="DestBadgeFontCombo" IsEditable="True" Margin="6,2"
                              ToolTip="Type or pick any installed font. Empty = Segoe UI."/>
                    <TextBox  Grid.Row="4" Grid.Column="2" x:Name="DestBadgeSizeBox" Padding="4" Margin="0,2"
                              Background="{DynamicResource InputBackground}"
                              Foreground="{DynamicResource PanelForeground}"
                              BorderBrush="{DynamicResource ButtonBorder}"
                              ToolTip="Font size in pixels (6–48)."/>
                </Grid>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Button size" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="Overall size of each destination button. Compact saves vertical space; Large makes them easier to hit."/>
                    <ComboBox Grid.Column="1" x:Name="DestButtonSizeCombo" Margin="6,2"
                              ToolTip="Compact, Normal, or Large.">
                        <ComboBoxItem Content="Compact"/>
                        <ComboBoxItem Content="Normal"/>
                        <ComboBoxItem Content="Large"/>
                    </ComboBox>
                </Grid>

                <TextBlock Text="Destinations" FontSize="16" FontWeight="Bold" Margin="0,0,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>
                <TextBlock Text="Use the + Add and ✎ Edit buttons in the main window. Listed here for reference."
                           Foreground="{DynamicResource MutedForeground}" Margin="0,0,0,4"/>
                <ListBox x:Name="DestinationsList" Height="160"
                         Background="{DynamicResource PanelBackground}"
                         Foreground="{DynamicResource PanelForeground}"
                         BorderBrush="{DynamicResource ButtonBorder}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="Bold"/>
                                <TextBlock Text="{Binding FolderPath}" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"/>
                                <TextBlock Text="{Binding HotKeyDisplay}" FontSize="11"
                                           Foreground="{DynamicResource MutedForeground}"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>

                <TextBlock Text="Find Duplicates" FontSize="16" FontWeight="Bold" Margin="0,16,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>
                <TextBlock Text="How tolerant the duplicate detector is. Lower = stricter (only nearly-identical photos match). Higher = looser (more matches, but also more false positives)."
                           Foreground="{DynamicResource MutedForeground}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="160"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Match threshold" VerticalAlignment="Center"
                               Foreground="{DynamicResource PanelForeground}"
                               ToolTip="dHash Hamming-distance threshold (0–16). Default 4."/>
                    <Slider Grid.Column="1" x:Name="DuplicateThresholdSlider"
                            Minimum="0" Maximum="16" SmallChange="1" LargeChange="2"
                            TickFrequency="1" IsSnapToTickEnabled="True" TickPlacement="BottomRight"
                            ValueChanged="DuplicateThresholdSlider_ValueChanged"
                            ToolTip="Drag to set how aggressively to match duplicates (0 = exact, 16 = very loose)"/>
                    <TextBlock Grid.Column="2" x:Name="DuplicateThresholdText" VerticalAlignment="Center"
                               TextAlignment="Right" Margin="6,0,0,0"
                               Foreground="{DynamicResource MutedForeground}"/>
                </Grid>

                <TextBlock Text="Diagnostics" FontSize="16" FontWeight="Bold" Margin="0,16,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>
                <TextBlock Text="Bundle the crash log, current state, and settings into a single text file you can share when reporting an issue."
                           Foreground="{DynamicResource MutedForeground}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Button Content="Save Debug Log…" Style="{StaticResource UtilityToolButton}"
                        HorizontalAlignment="Left" Click="SaveDebugLog_Click"
                        ToolTip="Save a debug log file you can attach to a bug report"/>

                <TextBlock Text="Performance" FontSize="16" FontWeight="Bold" Margin="0,16,0,8"
                           Foreground="{DynamicResource PanelForeground}"/>
                <TextBlock x:Name="ThumbCacheStatusText"
                           Foreground="{DynamicResource MutedForeground}" TextWrapping="Wrap" Margin="0,0,0,6"/>
                <Button Content="Clear Thumbnail Cache" Style="{StaticResource DangerToolButton}"
                        HorizontalAlignment="Left" Click="ClearThumbCache_Click"
                        ToolTip="Wipe both the in-memory and on-disk thumbnail cache. Thumbnails will be regenerated on the next folder load."/>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
